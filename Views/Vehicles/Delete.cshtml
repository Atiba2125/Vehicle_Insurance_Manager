@model VehicleShield.Models.Vehicle

@{
    ViewData["Title"] = "Delete Vehicle";
    Layout = "_AdminLayout";
}

<div class="page-header">

    <div class="page-header-left">
        <h1>Delete Vehicle</h1>
        <p>Remove this vehicle from the system permanently</p>
    </div>

    <div class="page-header-actions">

        <a asp-action="Index" class="btn btn-outline">
            Back to List
        </a>

    </div>

</div>


<div class="card">

    <div class="card-header">
        <h3 style="color:#ff6b6b;">
            Delete Confirmation
        </h3>
    </div>

    <div class="card-body">

        <div style="
            background:rgba(255,107,107,.08);
            border:1px solid rgba(255,107,107,.25);
            border-radius:12px;
            padding:18px;
            margin-bottom:25px;
            color:#ffb4b4;">

            <strong>Warning!</strong><br />
            This vehicle will be permanently deleted and this action cannot be undone.

        </div>


        <div class="content-grid cols-2">

            <div>

                <div style="margin-bottom:18px;">
                    <span style="color:var(--text-muted);">Vehicle Name</span>
                    <h5>@Model.VehicleName</h5>
                </div>

                <div style="margin-bottom:18px;">
                    <span style="color:var(--text-muted);">Owner Name</span>
                    <h5>@Model.OwnerName</h5>
                </div>

                <div style="margin-bottom:18px;">
                    <span style="color:var(--text-muted);">Vehicle Model</span>
                    <h5>@Model.VehicleModel</h5>
                </div>

                <div style="margin-bottom:18px;">
                    <span style="color:var(--text-muted);">Vehicle Version</span>
                    <h5>@Model.VehicleVersion</h5>
                </div>

            </div>


            <div>

                <div style="margin-bottom:18px;">
                    <span style="color:var(--text-muted);">Vehicle Number</span>
                    <h5>@Model.VehicleNumber</h5>
                </div>

                <div style="margin-bottom:18px;">
                    <span style="color:var(--text-muted);">Vehicle Rate</span>
                    <h5>PKR @Model.VehicleRate.ToString("N0")</h5>
                </div>

                <div style="margin-bottom:18px;">
                    <span style="color:var(--text-muted);">Body Number</span>
                    <h5>@Model.BodyNumber</h5>
                </div>

                <div style="margin-bottom:18px;">
                    <span style="color:var(--text-muted);">Engine Number</span>
                    <h5>@Model.EngineNumber</h5>
                </div>

            </div>

        </div>


        <form asp-action="Delete" style="margin-top:30px;">

            <input type="hidden" asp-for="VehicleId" />

            <div style="display:flex; gap:12px;">

                <button type="submit"
                        class="btn btn-danger">
                    Delete Vehicle
                </button>

                <a asp-action="Index"
                   class="btn btn-outline">
                    Cancel
                </a>

            </div>

        </form>

    </div>

</div>