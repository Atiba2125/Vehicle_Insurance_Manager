@model VehicleShield.Models.Vehicle

@{
    ViewData["Title"] = "Create Vehicle";
    Layout = "_AdminLayout";
}

<div class="page-header">
    <div class="page-header-left">
        <h1>Create Vehicle</h1>
        <p>Add a new vehicle for an existing customer</p>
    </div>

    <div class="page-header-actions">
        <a asp-action="Index" class="btn btn-outline">Back to List</a>
    </div>
</div>

<div class="card" style="max-width: 800px; margin: 0 auto;">
    <div class="card-header">
        <h3>Vehicle Information Form</h3>
    </div>

    <div class="card-body">

        <form asp-action="Create" method="post"
              style="display:flex; flex-direction:column; gap:16px;">

            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly"
                 style="color:#ff6b6b; font-size:0.85rem;">
            </div>

            <div class="form-group" style="padding:0;">
                <label style="color:var(--text-muted);">Customer</label>

                <select asp-for="CustomerId"
                        asp-items="ViewBag.Customers"
                        class="form-control"
                        style="width:100%; padding:10px; border-radius:8px; border:1px solid var(--card-border); background:var(--input-bg); color:#fff;">
                    <option value="">Select Customer</option>
                </select>
            </div>

            <div class="form-group" style="padding:0;">
                <label style="color:var(--text-muted);">Vehicle Name</label>
                <input asp-for="VehicleName"
                       class="form-control"
                       style="width:100%; padding:10px; border-radius:8px; border:1px solid var(--card-border); background:var(--input-bg); color:#fff;" />
            </div>

            <div class="form-group" style="padding:0;">
                <label style="color:var(--text-muted);">Vehicle Model</label>
                <input asp-for="VehicleModel"
                       class="form-control"
                       style="width:100%; padding:10px; border-radius:8px; border:1px solid var(--card-border); background:var(--input-bg); color:#fff;" />
            </div>

            <div class="form-group" style="padding:0;">
                <label style="color:var(--text-muted);">Vehicle Version</label>
                <input asp-for="VehicleVersion"
                       class="form-control"
                       style="width:100%; padding:10px; border-radius:8px; border:1px solid var(--card-border); background:var(--input-bg); color:#fff;" />
            </div>

            <div class="form-group" style="padding:0;">
                <label style="color:var(--text-muted);">Vehicle Rate</label>
                <input asp-for="VehicleRate"
                       class="form-control"
                       style="width:100%; padding:10px; border-radius:8px; border:1px solid var(--card-border); background:var(--input-bg); color:#fff;" />
            </div>

            <div class="form-group" style="padding:0;">
                <label style="color:var(--text-muted);">Body Number</label>
                <input asp-for="BodyNumber"
                       class="form-control"
                       style="width:100%; padding:10px; border-radius:8px; border:1px solid var(--card-border); background:var(--input-bg); color:#fff;" />
            </div>

            <div class="form-group" style="padding:0;">
                <label style="color:var(--text-muted);">Engine Number</label>
                <input asp-for="EngineNumber"
                       class="form-control"
                       style="width:100%; padding:10px; border-radius:8px; border:1px solid var(--card-border); background:var(--input-bg); color:#fff;" />
            </div>

            <div class="form-group" style="padding:0;">
                <label style="color:var(--text-muted);">Vehicle Number</label>
                <input asp-for="VehicleNumber"
                       class="form-control"
                       style="width:100%; padding:10px; border-radius:8px; border:1px solid var(--card-border); background:var(--input-bg); color:#fff;" />
            </div>

            <button type="submit"
                    class="btn btn-primary"
                    style="justify-content:center; padding:12px;">
                Save Vehicle
            </button>

        </form>

    </div>
</div>