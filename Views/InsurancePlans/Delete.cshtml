@model VehicleShield.Models.InsurancePlan

@{
    ViewData["Title"] = "Delete Insurance Plan";
    Layout = "_AdminLayout";
}

<div class="page-header">


    <div class="page-header-left">
        <h1>Delete Insurance Plan</h1>
        <p>
            Confirm insurance plan deletion
        </p>
    </div>

    <div class="page-header-actions">

        <a asp-action="Index"
           class="btn btn-outline">
            Back To List
        </a>

    </div>


</div>

<div class="card">

    <div class="card-header">
        <h3 style="color:#ff6b6b;">
            Delete Confirmation
        </h3>
    </div>

    <div class="card-body">

        <div style="
        padding:16px;
        border-radius:12px;
        background:rgba(255,107,107,.08);
        border:1px solid rgba(255,107,107,.2);
        margin-bottom:25px;">

            <strong style="color:#ff6b6b;">
                Warning:
            </strong>

            This insurance plan will be permanently deleted.
            This action cannot be undone.

        </div>

        <div class="content-grid cols-2">

            <div>

                <div style="margin-bottom:18px;">

                    <span style="color:var(--text-muted);">
                        Plan ID
                    </span>

                    <h5>
                        @Model.InsurancePlanId
                    </h5>

                </div>

                <div style="margin-bottom:18px;">

                    <span style="color:var(--text-muted);">
                        Plan Name
                    </span>

                    <h5>
                        @Model.PlanName
                    </h5>

                </div>

                <div style="margin-bottom:18px;">

                    <span style="color:var(--text-muted);">
                        Price
                    </span>

                    <h5 style="color:#4ade80;">
                        Rs. @Model.Price.ToString("N0")
                    </h5>

                </div>

            </div>

            <div>

                <div style="margin-bottom:18px;">

                    <span style="color:var(--text-muted);">
                        Popular Plan
                    </span>

                    <h5>
                        @(Model.IsPopular ? "Yes" : "No")
                    </h5>

                </div>

                <div style="margin-bottom:18px;">

                    <span style="color:var(--text-muted);">
                        Status
                    </span>

                    @if (Model.IsActive)
                    {
                        <h5 style="color:#4ade80;">
                            Active
                        </h5>
                    }
                    else
                    {
                        <h5 style="color:#ff6b6b;">
                            Inactive
                        </h5>
                    }

                </div>

            </div>

        </div>

        <hr />

        <br />
        <form asp-action="Delete"
              method="post">

            <input type="hidden"
                   asp-for="InsurancePlanId" />

            <div style="
            display:flex;
            gap:10px;
            align-items:center;">

                <button type="submit"
                        class="btn btn-danger">

                    Delete Plan

                </button>

                <a asp-action="Details"
                   asp-route-id="@Model.InsurancePlanId"
                   class="btn btn-outline">

                    Cancel

                </a>

            </div>

        </form>

 

</div>
