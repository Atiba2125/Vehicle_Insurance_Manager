@model VehicleShield.Models.Billing

@{
    ViewData["Title"] = "Edit Billing";
    Layout = "_AdminLayout";
}

<div class="page-header">
    <div class="page-header-left">
        <h1>Edit Billing</h1>
        <p>Update billing record and payment information</p>
    </div>

    <div class="page-header-actions">
        <a asp-action="Index" class="btn btn-outline">
            Back to List
        </a>
    </div>
</div>

<div class="card" style="max-width:900px; margin:0 auto;">
    <div class="card-header">
        <h3>Edit Billing Form</h3>
    </div>

    <div class="card-body">
        <form asp-action="Edit" method="post" style="display:flex; flex-direction:column; gap:16px;">
            @Html.AntiForgeryToken()

            <input type="hidden" asp-for="BillingId" />
            <input type="hidden" asp-for="CustomerId" />
            <input type="hidden" asp-for="PolicyId" />
            <input type="hidden" asp-for="PolicyNumber" />

            <div asp-validation-summary="ModelOnly" style="color:#ff6b6b; font-size:0.85rem;"></div>

            <div style="display:grid; grid-template-columns: 1fr 1fr; gap:16px;">
                <div class="form-group" style="padding:0;">
                    <label style="color:var(--text-muted); font-size:.85rem; margin-bottom:6px; display:block;">Bill Number</label>
                    <input asp-for="BillNo" class="form-control" style="width:100%; padding:12px; border-radius:10px;" readonly />
                </div>

                <div class="form-group" style="padding:0;">
                    <label style="color:var(--text-muted); font-size:.85rem; margin-bottom:6px; display:block;">Policy Number</label>
                    <input asp-for="PolicyNumber" class="form-control" style="width:100%; padding:12px; border-radius:10px;" readonly disabled />
                </div>
            </div>

            <div style="display:grid; grid-template-columns: 1fr 1fr; gap:16px;">
                <div class="form-group" style="padding:0;">
                    <label style="color:var(--text-muted); font-size:.85rem; margin-bottom:6px; display:block;">Bill Date</label>
                    <input asp-for="BillDate" type="date" class="form-control" style="width:100%; padding:12px; border-radius:10px;" />
                </div>

                <div class="form-group" style="padding:0;">
                    <label style="color:var(--text-muted); font-size:.85rem; margin-bottom:6px; display:block;">Amount (Rs.)</label>
                    <input asp-for="Amount" class="form-control" style="width:100%; padding:12px; border-radius:10px;" />
                </div>
            </div>

            <div style="display:grid; grid-template-columns: 1fr 1fr; gap:16px;">
                <div class="form-group" style="padding:0;">
                    <label style="color:var(--text-muted); font-size:.85rem; margin-bottom:6px; display:block;">Payment Status</label>
                    <select asp-for="PaymentStatus" class="form-control" style="width:100%; padding:12px; border-radius:10px;">
                        <option value="Paid">Paid</option>
                        <option value="Pending">Pending</option>
                    </select>
                </div>

                <div class="form-group" style="padding:0;">
                    <label style="color:var(--text-muted); font-size:.85rem; margin-bottom:6px; display:block;">Customer Name</label>
                    <input asp-for="CustomerName" class="form-control" style="width:100%; padding:12px; border-radius:10px;" />
                </div>
            </div>

            <div style="display:grid; grid-template-columns: 1fr 1fr; gap:16px;">
                <div class="form-group" style="padding:0;">
                    <label style="color:var(--text-muted); font-size:.85rem; margin-bottom:6px; display:block;">Customer Phone</label>
                    <input asp-for="CustomerPhone" class="form-control" style="width:100%; padding:12px; border-radius:10px;" />
                </div>

                <div class="form-group" style="padding:0;">
                    <label style="color:var(--text-muted); font-size:.85rem; margin-bottom:6px; display:block;">Address Proof</label>
                    <input asp-for="CustomerAddProve" class="form-control" style="width:100%; padding:12px; border-radius:10px;" />
                </div>
            </div>

            <h4 style="margin-top:16px; margin-bottom:8px; border-bottom:1px solid rgba(255,255,255,0.1); padding-bottom:8px; color:var(--text-muted);">Vehicle Details</h4>

            <div style="display:grid; grid-template-columns: 1fr 1fr; gap:16px;">
                <div class="form-group" style="padding:0;">
                    <label style="color:var(--text-muted); font-size:.85rem; margin-bottom:6px; display:block;">Vehicle Name</label>
                    <input asp-for="VehicleName" class="form-control" style="width:100%; padding:12px; border-radius:10px;" />
                </div>

                <div class="form-group" style="padding:0;">
                    <label style="color:var(--text-muted); font-size:.85rem; margin-bottom:6px; display:block;">Vehicle Model</label>
                    <input asp-for="VehicleModel" class="form-control" style="width:100%; padding:12px; border-radius:10px;" />
                </div>
            </div>

            <div style="display:grid; grid-template-columns: 1fr 1fr 1fr; gap:16px;">
                <div class="form-group" style="padding:0;">
                    <label style="color:var(--text-muted); font-size:.85rem; margin-bottom:6px; display:block;">Vehicle Rate (Rs.)</label>
                    <input asp-for="VehicleRate" class="form-control" style="width:100%; padding:12px; border-radius:10px;" />
                </div>

                <div class="form-group" style="padding:0;">
                    <label style="color:var(--text-muted); font-size:.85rem; margin-bottom:6px; display:block;">Body Number</label>
                    <input asp-for="VehicleBodyNumber" class="form-control" style="width:100%; padding:12px; border-radius:10px;" />
                </div>

                <div class="form-group" style="padding:0;">
                    <label style="color:var(--text-muted); font-size:.85rem; margin-bottom:6px; display:block;">Engine Number</label>
                    <input asp-for="VehicleEngineNumber" class="form-control" style="width:100%; padding:12px; border-radius:10px;" />
                </div>
            </div>

            <div style="display:flex; gap:12px; margin-top:20px;">
                <button type="submit" class="btn btn-primary" style="flex:1; justify-content:center; padding:12px;">
                    Save Changes
                </button>
                <a asp-action="Index" class="btn btn-outline" style="flex:1; text-align:center; padding:12px;">
                    Cancel
                </a>
            </div>
        </form>
    </div>
</div>