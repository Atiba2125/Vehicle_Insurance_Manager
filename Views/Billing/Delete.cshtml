@model VehicleShield.Models.Billing

@{
    ViewData["Title"] = "Delete Billing";
    Layout = "_AdminLayout";
}

<div class="page-header">
    <div class="page-header-left">
        <h1>Delete Billing Record</h1>
        <p>Confirm before permanently deleting this billing record</p>
    </div>

    <div class="page-header-actions">
        <a asp-action="Index" class="btn btn-outline">
            Back to List
        </a>
    </div>
</div>

<div class="card">

    <div class="card-header">
        <h3 style="color:#ff6b6b;">
            Are you sure you want to delete this billing record?
        </h3>
    </div>

    <div class="card-body">

        <div class="content-grid cols-2">

            <div>

                <div style="margin-bottom:16px;">
                    <span style="color:var(--text-muted);">Bill Number</span>
                    <h5>@Model.BillNo</h5>
                </div>

                <div style="margin-bottom:16px;">
                    <span style="color:var(--text-muted);">Policy Number</span>
                    <h5>@Model.PolicyNumber</h5>
                </div>

                <div style="margin-bottom:16px;">
                    <span style="color:var(--text-muted);">Customer Name</span>
                    <h5>@Model.CustomerName</h5>
                </div>

                <div style="margin-bottom:16px;">
                    <span style="color:var(--text-muted);">Phone Number</span>
                    <h5>@Model.CustomerPhone</h5>
                </div>

            </div>

            <div>

                <div style="margin-bottom:16px;">
                    <span style="color:var(--text-muted);">Vehicle Name</span>
                    <h5>@Model.VehicleName</h5>
                </div>

                <div style="margin-bottom:16px;">
                    <span style="color:var(--text-muted);">Vehicle Model</span>
                    <h5>@Model.VehicleModel</h5>
                </div>

                <div style="margin-bottom:16px;">
                    <span style="color:var(--text-muted);">Amount</span>
                    <h5>Rs. @Model.Amount.ToString("N0")</h5>
                </div>

                <div style="margin-bottom:16px;">
                    <span style="color:var(--text-muted);">Payment Status</span>

                    @if (Model.PaymentStatus == "Paid")
                    {
                        <h5 style="color:#4ade80;">Paid</h5>
                    }
                    else
                    {
                        <h5 style="color:#f87171;">
                            @Model.PaymentStatus
                        </h5>
                    }

                </div>

            </div>

        </div>

        <hr style="margin:25px 0; border-color:rgba(255,255,255,.08);" />

        <form asp-action="Delete" method="post">

            <input type="hidden" asp-for="BillingId" />

            <div style="display:flex; gap:10px;">

                <button type="submit"
                        class="btn btn-danger">
                    Delete Billing
                </button>

                <a asp-action="Index"
                   class="btn btn-outline">
                    Cancel
                </a>

            </div>

        </form>

    </div>

</div>