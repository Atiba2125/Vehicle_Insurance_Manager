@model IEnumerable<VehicleShield.Models.Billing>

@{
    ViewData["Title"] = "Billings";
    Layout = "_AdminLayout";
}

<div class="page-header">
    <div class="page-header-left">
        <h1>Manage Billings</h1>
        <p>View and manage all generated billing records and payments</p>
    </div>
</div>

<div class="card">

    <div class="card-header">
        <h3>Billing Records</h3>
    </div>

    <div class="card-body">

        <div class="table-wrap">

            <table>

                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Bill No</th>
                        <th>Policy No</th>
                        <th>Customer</th>
                        <th>Vehicle</th>
                        <th>Amount</th>
                        <th>Status</th>
                        <th>Bill Date</th>
                        <th style="width:260px;">Actions</th>
                    </tr>
                </thead>

                <tbody>

                    @foreach (var item in Model)
                    {
                        <tr>

                            <td>
                                @item.BillingId
                            </td>

                            <td style="font-weight:700; color:#fff;">
                                @item.BillNo
                            </td>

                            <td>
                                @item.PolicyNumber
                            </td>

                            <td>
                                @item.CustomerName
                            </td>

                            <td>
                                @item.VehicleName
                            </td>

                            <td style="font-weight:600;">
                                Rs. @item.Amount.ToString("N0")
                            </td>

                            <td>
                                @if (item.PaymentStatus == "Paid")
                                {
                                    <span style="color:#4ade80; font-weight:600;">
                                        ? Paid
                                    </span>
                                }
                                else
                                {
                                    <span style="color:#f87171; font-weight:600;">
                                        ? @item.PaymentStatus
                                    </span>
                                }
                            </td>

                            <td>
                                @item.BillDate.ToString("dd MMM yyyy")
                            </td>

                            <td>

                                <div style="display:flex; gap:8px; flex-wrap:wrap;">

                                    <a asp-action="Details"
                                       asp-route-id="@item.BillingId"
                                       class="btn btn-primary btn-sm">
                                        Details
                                    </a>

                                    <a asp-action="Edit"
                                       asp-route-id="@item.BillingId"
                                       class="btn btn-outline btn-sm">
                                        Edit
                                    </a>

                                    <a asp-action="Delete"
                                       asp-route-id="@item.BillingId"
                                       class="btn btn-danger btn-sm">
                                        Delete
                                    </a>

                                </div>

                            </td>

                        </tr>
                    }

                </tbody>

            </table>

        </div>

    </div>

</div>