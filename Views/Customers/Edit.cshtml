@model VehicleShield.Models.Customer
@{
    ViewData["Title"] = "Edit Customer";
    Layout = "_AdminLayout";
}

<div class="page-header">
    <div class="page-header-left">
        <h1>Edit Customer</h1>
        <p>Modify client profile information</p>
    </div>
    <div class="page-header-actions">
        <a asp-action="Index" class="btn btn-outline">Back to List</a>
    </div>
</div>

<div class="card" style="max-width: 600px; margin: 0 auto;">
    <div class="card-header">
        <h3>Edit Details Form</h3>
    </div>
    <div class="card-body">
        <form asp-action="Edit" method="post" style="display:flex; flex-direction:column; gap:16px;">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="CustomerId" />
            <div asp-validation-summary="ModelOnly" style="color: #ff6b6b; font-size: 0.85rem; margin-bottom: 10px;"></div>

            <div class="form-group" style="padding:0;">
                <label asp-for="CustomerName" style="color:var(--text-muted); font-size:0.85rem; margin-bottom:6px; display:block;">Customer Name</label>
                <input asp-for="CustomerName" class="form-control" required style="width: 100%; padding: 10px; border-radius: 8px; border: 1px solid var(--card-border); background: var(--input-bg); color: #fff;" />
                <span asp-validation-for="CustomerName" style="color: #ff6b6b; font-size: 0.75rem;"></span>
            </div>

            <div class="form-group" style="padding:0;">
                <label asp-for="CustomerAddress" style="color:var(--text-muted); font-size:0.85rem; margin-bottom:6px; display:block;">Customer Address</label>
                <input asp-for="CustomerAddress" class="form-control" required style="width: 100%; padding: 10px; border-radius: 8px; border: 1px solid var(--card-border); background: var(--input-bg); color: #fff;" />
                <span asp-validation-for="CustomerAddress" style="color: #ff6b6b; font-size: 0.75rem;"></span>
            </div>

            <div class="form-group" style="padding:0;">
                <label asp-for="CustomerPhone" style="color:var(--text-muted); font-size:0.85rem; margin-bottom:6px; display:block;">Phone Number</label>
                <input asp-for="CustomerPhone" class="form-control" required style="width: 100%; padding: 10px; border-radius: 8px; border: 1px solid var(--card-border); background: var(--input-bg); color: #fff;" />
                <span asp-validation-for="CustomerPhone" style="color: #ff6b6b; font-size: 0.75rem;"></span>
            </div>

            <button type="submit" class="btn btn-primary" style="justify-content:center; padding:12px; margin-top:10px;">
                Save Changes
            </button>
        </form>
    </div>
</div>
