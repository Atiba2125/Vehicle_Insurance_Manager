<!-- ========== CONTACT ========== -->
<section class="contact" id="contact">
    <div class="container">
        <div class="contact-grid">
            <div class="contact-info">
                <div class="section-tag">Get In Touch</div>
                <h2 class="section-title">We're Here to <span class="gradient-text">Help You</span></h2>
                <p class="contact-desc">Have questions about our insurance plans? Our expert team is always ready to assist you with the best advice and support.</p>
                <div class="contact-items">
                    <div class="contact-item">
                        <div class="ci-icon">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M21 16.92v2.08a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 014.5 10.8 19.79 19.79 0 011.43 2.18 2 2 0 013.5 0h2.08a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L6.91 7.91a16 16 0 006.18 6.18l.87-.87a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0121 16.92z" stroke="currentColor" stroke-width="2" /></svg>
                        </div>
                        <div>
                            <p class="ci-label">Phone</p>
                            <p class="ci-val">+92 0800-123-4567</p>
                        </div>
                    </div>
                    <div class="contact-item">
                        <div class="ci-icon">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" stroke="currentColor" stroke-width="2" /><path d="M22 6l-10 7L2 6" stroke="currentColor" stroke-width="2" /></svg>
                        </div>
                        <div>
                            <p class="ci-label">Email</p>
                            <p class="ci-val">support@vehicleshield.pk</p>
                        </div>
                    </div>
                    <div class="contact-item">
                        <div class="ci-icon">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z" stroke="currentColor" stroke-width="2" /><circle cx="12" cy="10" r="3" stroke="currentColor" stroke-width="2" /></svg>
                        </div>
                        <div>
                            <p class="ci-label">Address</p>
                            <p class="ci-val">Insurance Tower, I.I. Chundrigar Road, Karachi - 74200</p>
                        </div>
                    </div>
                </div>
            </div>
            <div class="contact-form-wrap">
                <form class="contact-form" id="contactForm" asp-controller="Home" asp-action="SubmitContact" method="post">
                    <div class="form-row">
                        <div class="form-group">
                            <label for="contactName">Full Name</label>
                            <input type="text" id="contactName" name="contactName" placeholder="Your full name" required />
                        </div>
                        <div class="form-group">
                            <label for="contactPhone">Phone Number</label>
                            <input type="tel" id="contactPhone" name="contactPhone" placeholder="+92 3XX XXXXXXX" required />
                        </div>
                    </div>
                    <div class="form-group">
                        <label for="contactEmail">Email Address</label>
                        <input type="email" id="contactEmail" name="contactEmail" placeholder="your@email.com" required />
                    </div>
                    <div class="form-group">
                        <label for="contactSubject">Subject</label>
                        <select id="contactSubject" name="contactSubject" required>
                            <option value="">Select a subject</option>
                            <option>New Policy Inquiry</option>
                            <option>Claim Assistance</option>
                            <option>Policy Renewal</option>
                            <option>General Query</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label for="contactMessage">Message</label>
                        <textarea id="contactMessage" name="contactMessage" rows="4" placeholder="How can we help you?" required></textarea>
                    </div>
                    <button type="submit" class="btn btn-primary btn-block">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M22 2L11 13" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" /><path d="M22 2L15 22 11 13 2 9l20-7z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" /></svg>
                        Send Message
                    </button>
                </form>
            </div>
        </div>
    </div>
</section>

