@{
    ViewData["Title"] = "Drive with Confidence – VehicleShield";
}

<!-- ========== HERO ========== -->
<section class="hero" id="home">
    <div class="hero-bg">
        <div class="hero-orb orb-1"></div>
        <div class="hero-orb orb-2"></div>
        <div class="hero-orb orb-3"></div>
        <div class="grid-overlay"></div>
    </div>
    <div class="container">
        <div class="hero-content">
            <div class="hero-badge">
                <span class="badge-dot"></span>
                Trusted by 50,000+ vehicle owners
            </div>
            <h1 class="hero-title">
                Drive with
                <span class="gradient-text">Confidence</span><br />
                Insure with Intelligence
            </h1>
            <p class="hero-desc">
                VehicleShield provides comprehensive, affordable, and instant vehicle insurance.
                Get covered in minutes with our smart online portal designed for the modern driver.
            </p>
            <div class="hero-actions">
                <a asp-controller="Account" asp-action="Register" class="btn btn-primary btn-lg">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" /></svg>
                    Get Insured Now
                </a>
                <a href="#insurance-types" class="btn btn-outline btn-lg">
                    Explore Plans
                </a>
            </div>
            <div class="hero-stats">
                <div class="stat-item">
                    <span class="stat-value">@ViewBag.HappyClients+</span>
                    <span class="stat-label">Happy Clients</span>
                </div>
                <div class="stat-divider"></div>
                <div class="stat-item">
                    <span class="stat-value">₹@string.Format("{0:N0}", ViewBag.ClaimsSettled)</span>
                    <span class="stat-label">Claims Settled</span>
                </div>
                <div class="stat-divider"></div>
                <div class="stat-item">
                    <span class="stat-value">@ViewBag.ClaimSuccess%</span>
                    <span class="stat-label">Claim Success</span>
                </div>
                <div class="stat-divider"></div>
                <div class="stat-item">
                    <span class="stat-value">24/7</span>
                    <span class="stat-label">Support</span>
                </div>
            </div>
        </div>
        <div class="hero-visual">
            <div class="hero-card main-card">
                <div class="card-header">
                    <div class="card-icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M20 8H4L2 14v4h20v-4L20 8z" stroke="#6C63FF" stroke-width="2" stroke-linejoin="round" /><circle cx="7" cy="18" r="2" stroke="#6C63FF" stroke-width="2" /><circle cx="17" cy="18" r="2" stroke="#6C63FF" stroke-width="2" /><path d="M4 8V6a2 2 0 012-2h12a2 2 0 012 2v2" stroke="#6C63FF" stroke-width="2" /></svg></div>
                    <span>Active Policy</span>
                    <span class="card-badge">Active</span>
                </div>
                <div class="card-body">
                    <p class="card-vehicle">Toyota Fortuner 2023</p>
                    <p class="card-policy">Policy #VS-2026-00892</p>
                    <div class="card-progress">
                        <div class="progress-bar" style="width:68%"></div>
                    </div>
                    <div class="card-dates">
                        <span>Jan 01, 2026</span>
                        <span>Dec 31, 2026</span>
                    </div>
                </div>
            </div>
            <div class="hero-card floating-card card-claim">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none"><path d="M9 12l2 2 4-4" stroke="#3ECFCF" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" /><path d="M21 12c0 4.97-4.03 9-9 9s-9-4.03-9-9 4.03-9 9-9 9 4.03 9 9z" stroke="#3ECFCF" stroke-width="2" /></svg>
                <div>
                    <p class="fc-label">Claim Settled</p>
                    <p class="fc-value">₹45,000</p>
                </div>
            </div>
            <div class="hero-card floating-card card-premium">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" stroke="#F7C948" stroke-width="2" stroke-linejoin="round" /></svg>
                <div>
                    <p class="fc-label">Monthly Premium</p>
                    <p class="fc-value">₹2,850</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ========== FEATURES ========== -->
<section class="features-strip">
    <div class="container">
        <div class="features-grid">
            <div class="feature-item">
                <div class="feature-icon fi-blue">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" /></svg>
                </div>
                <div>
                    <h3>Instant Policy</h3>
                    <p>Get insured in under 5 minutes</p>
                </div>
            </div>
            <div class="feature-item">
                <div class="feature-icon fi-teal">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" stroke="currentColor" stroke-width="2" /></svg>
                </div>
                <div>
                    <h3>100% Secure</h3>
                    <p>Bank-grade data encryption</p>
                </div>
            </div>
            <div class="feature-item">
                <div class="feature-icon fi-purple">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M22 12h-4l-3 9L9 3l-3 9H2" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" /></svg>
                </div>
                <div>
                    <h3>Fast Claims</h3>
                    <p>99.2% claim settlement rate</p>
                </div>
            </div>
            <div class="feature-item">
                <div class="feature-icon fi-gold">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="2" /><path d="M12 6v6l4 2" stroke="currentColor" stroke-width="2" stroke-linecap="round" /></svg>
                </div>
                <div>
                    <h3>24/7 Support</h3>
                    <p>Round-the-clock assistance</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ========== ABOUT ========== -->
<section class="about" id="about">
    <div class="container">
        <div class="about-grid">
            <div class="about-visual">
                <div class="about-img-wrap">
                    <div class="about-img-bg"></div>
                    <div class="about-img-card">
                        <div class="abt-metric"><span class="abt-val">15+</span><span class="abt-lbl">Years Experience</span></div>
                        <div class="abt-metric"><span class="abt-val">₹500Cr</span><span class="abt-lbl">Total Coverage</span></div>
                        <div class="abt-metric"><span class="abt-val">200+</span><span class="abt-lbl">Partner Garages</span></div>
                    </div>
                </div>
                <div class="about-decoration">
                    <div class="deco-circle c1"></div>
                    <div class="deco-circle c2"></div>
                </div>
            </div>
            <div class="about-content">
                <div class="section-tag">About VehicleShield</div>
                <h2 class="section-title">India's Most Trusted <span class="gradient-text">Vehicle Insurance</span> Platform</h2>
                <p class="about-desc">
                    Founded in 2009, VehicleShield has been at the forefront of revolutionizing vehicle insurance in India.
                    We combine cutting-edge technology with deep industry expertise to deliver insurance solutions that
                    truly protect what matters most — your vehicle and your peace of mind.
                </p>
                <ul class="about-list">
                    <li>
                        <div class="list-icon">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M20 6L9 17l-5-5" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" /></svg>
                        </div>
                        Comprehensive coverage for all vehicle types
                    </li>
                    <li>
                        <div class="list-icon">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M20 6L9 17l-5-5" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" /></svg>
                        </div>
                        Transparent pricing with zero hidden charges
                    </li>
                    <li>
                        <div class="list-icon">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M20 6L9 17l-5-5" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" /></svg>
                        </div>
                        Dedicated claim support team
                    </li>
                    <li>
                        <div class="list-icon">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M20 6L9 17l-5-5" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" /></svg>
                        </div>
                        IRDAI regulated & fully compliant
                    </li>
                </ul>
                <a asp-controller="Account" asp-action="Register" class="btn btn-primary">Join VehicleShield</a>
            </div>
        </div>
    </div>
</section>

<!-- ========== INSURANCE TYPES ========== -->
<section class="insurance-types" id="insurance-types">
    <div class="container">
        <div class="section-header">
            <div class="section-tag">Coverage Plans</div>
            <h2 class="section-title">Choose the Right <span class="gradient-text">Insurance Plan</span></h2>
            <p class="section-desc">Flexible insurance solutions tailored to meet every driver's unique needs and budget.</p>
        </div>
        <div class="plans-grid">
            <div class="plan-card" data-plan="basic">
                <div class="plan-icon">
                    <svg width="36" height="36" viewBox="0 0 24 24" fill="none"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" stroke="currentColor" stroke-width="2" /></svg>
                </div>
                <h3>Third Party</h3>
                <p class="plan-desc">Basic mandatory coverage that protects you against third-party liabilities. Ideal for older vehicles.</p>
                <div class="plan-price"><span class="price-from">Starting from</span><span class="price-val">₹2,094/yr</span></div>
                <ul class="plan-features">
                    <li><svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M20 6L9 17l-5-5" stroke="#3ECFCF" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" /></svg> Third-party liability</li>
                    <li><svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M20 6L9 17l-5-5" stroke="#3ECFCF" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" /></svg> Property damage cover</li>
                    <li><svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M20 6L9 17l-5-5" stroke="#3ECFCF" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" /></svg> Legal compliance</li>
                    <li class="plan-feat-no"><svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M18 6L6 18M6 6l12 12" stroke="#666" stroke-width="2" stroke-linecap="round" /></svg> Own damage cover</li>
                </ul>
                <a asp-controller="Account" asp-action="Register" class="btn btn-outline plan-btn">Get This Plan</a>
            </div>
            <div class="plan-card plan-popular" data-plan="comprehensive">
                <div class="plan-popular-badge">Most Popular</div>
                <div class="plan-icon">
                    <svg width="36" height="36" viewBox="0 0 24 24" fill="none"><path d="M20 8H4L2 14v4h20v-4L20 8z" stroke="currentColor" stroke-width="2" stroke-linejoin="round" /><circle cx="7" cy="18" r="2" stroke="currentColor" stroke-width="2" /><circle cx="17" cy="18" r="2" stroke="currentColor" stroke-width="2" /></svg>
                </div>
                <h3>Comprehensive</h3>
                <p class="plan-desc">All-inclusive protection covering your vehicle and third-party liabilities. The complete package for peace of mind.</p>
                <div class="plan-price"><span class="price-from">Starting from</span><span class="price-val">₹7,500/yr</span></div>
                <ul class="plan-features">
                    <li><svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M20 6L9 17l-5-5" stroke="#6C63FF" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" /></svg> Own damage cover</li>
                    <li><svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M20 6L9 17l-5-5" stroke="#6C63FF" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" /></svg> Third-party liability</li>
                    <li><svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M20 6L9 17l-5-5" stroke="#6C63FF" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" /></svg> Theft & fire protection</li>
                    <li><svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M20 6L9 17l-5-5" stroke="#6C63FF" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" /></svg> Natural disaster cover</li>
                    <li><svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M20 6L9 17l-5-5" stroke="#6C63FF" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" /></svg> Zero depreciation add-on</li>
                </ul>
                <a asp-controller="Account" asp-action="Register" class="btn btn-primary plan-btn">Get This Plan</a>
            </div>
            <div class="plan-card" data-plan="premium">
                <div class="plan-icon">
                    <svg width="36" height="36" viewBox="0 0 24 24" fill="none"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" stroke="currentColor" stroke-width="2" stroke-linejoin="round" /></svg>
                </div>
                <h3>Premium Elite</h3>
                <p class="plan-desc">The ultimate protection package with maximum coverage, zero depreciation, and priority claim handling.</p>
                <div class="plan-price"><span class="price-from">Starting from</span><span class="price-val">₹14,000/yr</span></div>
                <ul class="plan-features">
                    <li><svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M20 6L9 17l-5-5" stroke="#F7C948" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" /></svg> Everything in Comprehensive</li>
                    <li><svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M20 6L9 17l-5-5" stroke="#F7C948" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" /></svg> Roadside assistance</li>
                    <li><svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M20 6L9 17l-5-5" stroke="#F7C948" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" /></svg> Priority claim settlement</li>
                    <li><svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M20 6L9 17l-5-5" stroke="#F7C948" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" /></svg> Engine protection</li>
                    <li><svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M20 6L9 17l-5-5" stroke="#F7C948" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" /></svg> Dedicated relationship manager</li>
                </ul>
                <a asp-controller="Account" asp-action="Register" class="btn btn-outline plan-btn">Get This Plan</a>
            </div>
        </div>
    </div>
</section>

<!-- ========== HOW IT WORKS ========== -->
<section class="how-it-works">
    <div class="container">
        <div class="section-header">
            <div class="section-tag">Simple Process</div>
            <h2 class="section-title">Get Insured in <span class="gradient-text">3 Easy Steps</span></h2>
        </div>
        <div class="steps-grid">
            <div class="step-card">
                <div class="step-number">01</div>
                <div class="step-icon">
                    <svg width="32" height="32" viewBox="0 0 24 24" fill="none"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2" stroke="currentColor" stroke-width="2" stroke-linecap="round" /><circle cx="12" cy="7" r="4" stroke="currentColor" stroke-width="2" /></svg>
                </div>
                <h3>Register & Fill Form</h3>
                <p>Create your account and fill in your vehicle and personal details in our simple online form.</p>
            </div>
            <div class="step-arrow">→</div>
            <div class="step-card">
                <div class="step-number">02</div>
                <div class="step-icon">
                    <svg width="32" height="32" viewBox="0 0 24 24" fill="none"><rect x="3" y="3" width="18" height="18" rx="2" stroke="currentColor" stroke-width="2" /><path d="M3 9h18M9 21V9" stroke="currentColor" stroke-width="2" /></svg>
                </div>
                <h3>Choose Your Plan</h3>
                <p>Compare our insurance plans and select the one that best fits your needs and budget.</p>
            </div>
            <div class="step-arrow">→</div>
            <div class="step-card">
                <div class="step-number">03</div>
                <div class="step-icon">
                    <svg width="32" height="32" viewBox="0 0 24 24" fill="none"><path d="M22 12h-4l-3 9L9 3l-3 9H2" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" /></svg>
                </div>
                <h3>Get Instant Coverage</h3>
                <p>Complete payment and receive your policy document instantly. Drive protected from day one!</p>
            </div>
        </div>
    </div>
</section>

