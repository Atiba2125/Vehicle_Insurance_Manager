@model IEnumerable<VehicleShield.Models.InsurancePlan>
@{
    ViewData["Title"] = "Drive with Confidence – VehicleShield";
    var approvedFeedbacks = ViewBag.ApprovedFeedbacks as List<VehicleShield.Models.CustomerFeedback> ?? new List<VehicleShield.Models.CustomerFeedback>();
}

<!-- ========== HERO ========== -->
<section class="hero" id="home">
    <div class="hero-bg">
        <div class="hero-orb orb-1"></div>
        <div class="hero-orb orb-2"></div>
        <div class="hero-orb orb-3"></div>
        <div class="grid-overlay"></div>
    </div>
    <div class="container">
        <div class="hero-content">
            <div class="hero-badge">
                <span class="badge-dot"></span>
                Trusted by 50,000+ vehicle owners across Pakistan
            </div>
            <h1 class="hero-title">
                Drive with
                <span class="gradient-text">Confidence</span><br />
                Insure with Intelligence
            </h1>
            <p class="hero-desc">
                VehicleShield provides comprehensive, affordable, and instant vehicle insurance.
                Get covered in minutes with our smart online portal designed for the modern driver.
            </p>
            <div class="hero-actions">
                <a asp-controller="Account" asp-action="Register" class="btn btn-primary btn-lg">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" /></svg>
                    Get Insured Now
                </a>
                <a href="#insurance-types" class="btn btn-outline btn-lg">
                    Explore Plans
                </a>
            </div>
            <div class="hero-stats">
                <div class="stat-item">
                    <span class="stat-value">@ViewBag.HappyClients+</span>
                    <span class="stat-label">Happy Clients</span>
                </div>
                <div class="stat-divider"></div>
                <div class="stat-item">
                    <span class="stat-value">Rs.@string.Format("{0:N0}", ViewBag.ClaimsSettled)</span>
                    <span class="stat-label">Claims Settled</span>
                </div>
                <div class="stat-divider"></div>
                <div class="stat-item">
                    <span class="stat-value">@ViewBag.ClaimSuccess%</span>
                    <span class="stat-label">Claim Success</span>
                </div>
                <div class="stat-divider"></div>
                <div class="stat-item">
                    <span class="stat-value">24/7</span>
                    <span class="stat-label">Support</span>
                </div>
            </div>
        </div>
        <div class="hero-visual">
            <div class="hero-card main-card">
                <div class="card-header">
                    <div class="card-icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M20 8H4L2 14v4h20v-4L20 8z" stroke="var(--primary)" stroke-width="2" stroke-linejoin="round" /><circle cx="7" cy="18" r="2" stroke="var(--primary)" stroke-width="2" /><circle cx="17" cy="18" r="2" stroke="var(--primary)" stroke-width="2" /><path d="M4 8V6a2 2 0 012-2h12a2 2 0 012 2v2" stroke="var(--primary)" stroke-width="2" /></svg></div>
                    <span>Active Policy</span>
                    <span class="card-badge">Active</span>
                </div>
                <div class="card-body">
                    <p class="card-vehicle">Toyota Fortuner 2023</p>
                    <p class="card-policy">Policy #VS-2026-00892</p>
                    <div class="card-progress">
                        <div class="progress-bar" style="width:68%"></div>
                    </div>
                    <div class="card-dates">
                        <span>Jan 01, 2026</span>
                        <span>Dec 31, 2026</span>
                    </div>
                </div>
            </div>
            <div class="hero-card floating-card card-claim">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none"><path d="M9 12l2 2 4-4" stroke="var(--secondary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" /><path d="M21 12c0 4.97-4.03 9-9 9s-9-4.03-9-9 4.03-9 9-9 9 4.03 9 9z" stroke="var(--secondary)" stroke-width="2" /></svg>
                <div>
                    <p class="fc-label">Claim Settled</p>
                    <p class="fc-value">Rs. 45,000</p>
                </div>
            </div>
            <div class="hero-card floating-card card-premium">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" stroke="#F7C948" stroke-width="2" stroke-linejoin="round" /></svg>
                <div>
                    <p class="fc-label">Monthly Premium</p>
                    <p class="fc-value">Rs. 2,850</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ========== FEATURES ========== -->
<section class="features-strip">
    <div class="container">
        <div class="features-grid">
            <div class="feature-item">
                <div class="feature-icon fi-blue">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" /></svg>
                </div>
                <div>
                    <h3>Instant Policy</h3>
                    <p>Get insured in under 5 minutes</p>
                </div>
            </div>
            <div class="feature-item">
                <div class="feature-icon fi-teal">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" stroke="currentColor" stroke-width="2" /></svg>
                </div>
                <div>
                    <h3>100% Secure</h3>
                    <p>Bank-grade data encryption</p>
                </div>
            </div>
            <div class="feature-item">
                <div class="feature-icon fi-purple">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M22 12h-4l-3 9L9 3l-3 9H2" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" /></svg>
                </div>
                <div>
                    <h3>Fast Claims</h3>
                    <p>99.2% claim settlement rate</p>
                </div>
            </div>
            <div class="feature-item">
                <div class="feature-icon fi-gold">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="2" /><path d="M12 6v6l4 2" stroke="currentColor" stroke-width="2" stroke-linecap="round" /></svg>
                </div>
                <div>
                    <h3>24/7 Support</h3>
                    <p>Round-the-clock assistance</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ========== ABOUT ========== -->
<section class="about" id="about">
    <div class="container">
        <div class="about-grid">
            <div class="about-visual">
                <div class="about-img-wrap">
                    <div class="about-img-bg"></div>
                    <div class="about-img-card">
                        <div class="abt-metric"><span class="abt-val">15+</span><span class="abt-lbl">Years Experience</span></div>
                        <div class="abt-metric"><span class="abt-val">Rs.500Cr</span><span class="abt-lbl">Total Coverage</span></div>
                        <div class="abt-metric"><span class="abt-val">200+</span><span class="abt-lbl">Partner Workshops</span></div>
                    </div>
                </div>
                <div class="about-decoration">
                    <div class="deco-circle c1"></div>
                    <div class="deco-circle c2"></div>
                </div>
            </div>
            <div class="about-content">
                <div class="section-tag">About VehicleShield</div>
                <h2 class="section-title">Pakistan's Most Trusted <span class="gradient-text">Vehicle Insurance</span> Platform</h2>
                <p class="about-desc">
                    Founded in 2009, VehicleShield has been at the forefront of revolutionizing vehicle insurance in Pakistan.
                    We combine cutting-edge technology with deep industry expertise to deliver insurance solutions that
                    truly protect what matters most — your vehicle and your peace of mind.
                </p>
                <ul class="about-list">
                    <li>
                        <div class="list-icon">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M20 6L9 17l-5-5" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" /></svg>
                        </div>
                        Comprehensive coverage for all vehicle types
                    </li>
                    <li>
                        <div class="list-icon">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M20 6L9 17l-5-5" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" /></svg>
                        </div>
                        Transparent pricing with zero hidden charges
                    </li>
                    <li>
                        <div class="list-icon">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M20 6L9 17l-5-5" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" /></svg>
                        </div>
                        Dedicated claim support team
                    </li>
                    <li>
                        <div class="list-icon">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M20 6L9 17l-5-5" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" /></svg>
                        </div>
                        SECP regulated & fully compliant
                    </li>
                </ul>
                <a asp-controller="Account" asp-action="Register" class="btn btn-primary">Join VehicleShield</a>
            </div>
        </div>
    </div>
</section>

<!-- ========== INSURANCE TYPES ========== -->
<section class="insurance-types" id="insurance-types">
    <div class="container">
        <div class="section-header">
            <div class="section-tag">Coverage Plans</div>
            <h2 class="section-title">Choose the Right <span class="gradient-text">Insurance Plan</span></h2>
            <p class="section-desc">Flexible insurance solutions tailored to meet every driver's unique needs and budget.</p>
        </div>
        <div class="plans-grid">
            @if (Model != null && Model.Any())
            {
                @foreach (var plan in Model)
                {
                    <div class="plan-card @(plan.IsPopular ? "plan-popular" : "")" data-plan="@plan.PlanName.ToLower().Replace(" ", "-")">
                        @if (plan.IsPopular)
                        {
                            <div class="plan-popular-badge">Most Popular</div>
                        }
                        <div class="plan-icon">
                            @if (plan.PlanName.Contains("Third Party"))
                            {
                                <svg width="36" height="36" viewBox="0 0 24 24" fill="none"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" stroke="currentColor" stroke-width="2" /></svg>
                            }
                            else if (plan.PlanName.Contains("Comprehensive"))
                            {
                                <svg width="36" height="36" viewBox="0 0 24 24" fill="none"><path d="M20 8H4L2 14v4h20v-4L20 8z" stroke="currentColor" stroke-width="2" stroke-linejoin="round" /><circle cx="7" cy="18" r="2" stroke="currentColor" stroke-width="2" /><circle cx="17" cy="18" r="2" stroke="currentColor" stroke-width="2" /></svg>
                            }
                            else
                            {
                                <svg width="36" height="36" viewBox="0 0 24 24" fill="none"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" stroke="currentColor" stroke-width="2" stroke-linejoin="round" /></svg>
                            }
                        </div>
                        <h3>@plan.PlanName</h3>
                        <p class="plan-desc">@plan.Description</p>
                        <div class="plan-price">
                            <span class="price-from">Premium Rate</span>
                            <span class="price-val">@plan.Price.ToString("0.##")% IDV / yr</span>
                        </div>
                        <ul class="plan-features">
                            @if (!string.IsNullOrEmpty(plan.Features))
                            {
                                var features = plan.Features.Split(',', StringSplitOptions.RemoveEmptyEntries);
                                foreach (var feat in features)
                                {
                                    <li>
                                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none">
                                            <path d="M20 6L9 17l-5-5" stroke="@(plan.IsPopular ? "#FFD600" : "var(--primary)")" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" />
                                        </svg> 
                                        @feat.Trim()
                                    </li>
                                }
                            }
                            else
                            {
                                <li>
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none">
                                        <path d="M20 6L9 17l-5-5" stroke="var(--primary)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" />
                                    </svg> 
                                    Standard Coverage
                                </li>
                            }
                        </ul>
                        <a asp-controller="Account" asp-action="Register" class="btn @(plan.IsPopular ? "btn-primary" : "btn-outline") plan-btn">Get This Plan</a>
                    </div>
                }
            }
            else
            {
                <div class="plan-card" style="grid-column: 1 / -1; text-align: center; padding: 40px; color: var(--text-muted);">
                    <p>No insurance plans are currently available. Please check back later.</p>
                </div>
            }
        </div>
    </div>
</section>

<!-- ========== HOW IT WORKS ========== -->
<section class="how-it-works">
    <div class="container">
        <div class="section-header">
            <div class="section-tag">Simple Process</div>
            <h2 class="section-title">Get Insured in <span class="gradient-text">3 Easy Steps</span></h2>
        </div>
        <div class="steps-grid">
            <div class="step-card">
                <div class="step-number">01</div>
                <div class="step-icon">
                    <svg width="32" height="32" viewBox="0 0 24 24" fill="none"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2" stroke="currentColor" stroke-width="2" stroke-linecap="round" /><circle cx="12" cy="7" r="4" stroke="currentColor" stroke-width="2" /></svg>
                </div>
                <h3>Register & Fill Form</h3>
                <p>Create your account and fill in your vehicle and personal details in our simple online form.</p>
            </div>
            <div class="step-arrow">→</div>
            <div class="step-card">
                <div class="step-number">02</div>
                <div class="step-icon">
                    <svg width="32" height="32" viewBox="0 0 24 24" fill="none"><rect x="3" y="3" width="18" height="18" rx="2" stroke="currentColor" stroke-width="2" /><path d="M3 9h18M9 21V9" stroke="currentColor" stroke-width="2" /></svg>
                </div>
                <h3>Choose Your Plan</h3>
                <p>Compare our insurance plans and select the one that best fits your needs and budget.</p>
            </div>
            <div class="step-arrow">→</div>
            <div class="step-card">
                <div class="step-number">03</div>
                <div class="step-icon">
                    <svg width="32" height="32" viewBox="0 0 24 24" fill="none"><path d="M22 12h-4l-3 9L9 3l-3 9H2" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" /></svg>
                </div>
                <h3>Get Instant Coverage</h3>
                <p>Complete payment and receive your policy document instantly. Drive protected from day one!</p>
            </div>
        </div>
    </div>
</section>

<!-- ========== TESTIMONIALS ========== -->
<section class="testimonials" id="testimonials">
    <div class="container">
        <div class="section-header">
            <div class="section-tag">Customer Stories</div>
            <h2 class="section-title">What Our <span class="gradient-text">Customers Say</span></h2>
            <p class="section-desc">Real experiences from thousands of satisfied VehicleShield customers across Pakistan.</p>
        </div>

        <!-- Stats Bar -->
        <div class="tc-stats-bar">
            <div class="tc-stat">
                <span class="tc-stat-val">50,000+</span>
                <span class="tc-stat-lbl">Happy Customers</span>
            </div>
            <div class="tc-stat-sep"></div>
            <div class="tc-stat">
                <span class="tc-stat-val">4.9★</span>
                <span class="tc-stat-lbl">Average Rating</span>
            </div>
            <div class="tc-stat-sep"></div>
            <div class="tc-stat">
                <span class="tc-stat-val">99.2%</span>
                <span class="tc-stat-lbl">Claim Success</span>
            </div>
            <div class="tc-stat-sep"></div>
            <div class="tc-stat">
                <span class="tc-stat-val">3 Days</span>
                <span class="tc-stat-lbl">Avg. Settlement</span>
            </div>
        </div>

        <!-- Marquee Row 1 — scrolls left -->
        <div class="tc-marquee-wrapper">
            <div class="tc-marquee tc-marquee-left">
                @for (int loop = 0; loop < 2; loop++)
                {
                    <!-- Card 1 -->
                    <div class="tc-card">
                        <div class="tc-card-top">
                            <div class="tc-card-avatar av1">AR</div>
                            <div class="tc-card-info">
                                <p class="tc-card-name">Ahmed Raza</p>
                                <p class="tc-card-role">Business Owner, Karachi</p>
                            </div>
                            <span class="tc-verified">✓ Verified</span>
                        </div>
                        <div class="tc-card-stars">★★★★★</div>
                        <p class="tc-card-text">VehicleShield ne insurance ka poora process bahut aasaan bana diya. 3 din mein sab kuch settle ho gaya. Zabardast service!</p>
                        <div class="tc-card-tag">Comprehensive Plan</div>
                    </div>
                    <!-- Card 2 -->
                    <div class="tc-card">
                        <div class="tc-card-top">
                            <div class="tc-card-avatar av2">SF</div>
                            <div class="tc-card-info">
                                <p class="tc-card-name">Sara Farooq</p>
                                <p class="tc-card-role">Software Engineer, Lahore</p>
                            </div>
                            <span class="tc-verified">✓ Verified</span>
                        </div>
                        <div class="tc-card-stars">★★★★★</div>
                        <p class="tc-card-text">Online portal bohat user-friendly hai. Maine 2 minute mein apni policy renew kar li. Sab se acha insurance experience!</p>
                        <div class="tc-card-tag">Policy Renewal</div>
                    </div>
                    <!-- Card 3 -->
                    <div class="tc-card tc-card-gold">
                        <div class="tc-card-top">
                            <div class="tc-card-avatar av3">UK</div>
                            <div class="tc-card-info">
                                <p class="tc-card-name">Usman Khan</p>
                                <p class="tc-card-role">Doctor, Islamabad</p>
                            </div>
                            <span class="tc-verified">✓ Verified</span>
                        </div>
                        <div class="tc-card-stars">★★★★★</div>
                        <p class="tc-card-text">Koi hidden charges nahi. Bilkul transparent pricing. Premium Elite plan ne mujhe poora sukoon diya hai.</p>
                        <div class="tc-card-tag">Premium Elite</div>
                    </div>
                    <!-- Card 4 -->
                    <div class="tc-card">
                        <div class="tc-card-top">
                            <div class="tc-card-avatar av4">ZA</div>
                            <div class="tc-card-info">
                                <p class="tc-card-name">Zara Akhtar</p>
                                <p class="tc-card-role">Teacher, Peshawar</p>
                            </div>
                            <span class="tc-verified">✓ Verified</span>
                        </div>
                        <div class="tc-card-stars">★★★★★</div>
                        <p class="tc-card-text">Raat ko meri gaari kharab ho gayi aur unhone 20 minute mein roadside assistance bhej di. Waqai kabile taarif service!</p>
                        <div class="tc-card-tag">24/7 Support</div>
                    </div>
                    <!-- Card 5 -->
                    <div class="tc-card">
                        <div class="tc-card-top">
                            <div class="tc-card-avatar av5">MH</div>
                            <div class="tc-card-info">
                                <p class="tc-card-name">Muhammad Hamza</p>
                                <p class="tc-card-role">Engineer, Faisalabad</p>
                            </div>
                            <span class="tc-verified">✓ Verified</span>
                        </div>
                        <div class="tc-card-stars">★★★★★</div>
                        <p class="tc-card-text">Bahut hi fast claim settlement mila. Mere dost bhi ab VehicleShield use kar rahe hain. Best decision tha yeh insurance lena!</p>
                        <div class="tc-card-tag">Third Party</div>
                    </div>

                    <!-- Dynamic Approved Feedbacks (Even indexes) -->
                    @foreach (var fb in approvedFeedbacks.Where((f, idx) => idx % 2 == 0))
                    {
                        var nameParts = fb.CustomerName.Split(' ', StringSplitOptions.RemoveEmptyEntries);
                        var initials = nameParts.Length >= 2
                            ? $"{nameParts[0][0]}{nameParts[1][0]}"
                            : (fb.CustomerName.Length >= 2 ? fb.CustomerName.Substring(0, 2) : fb.CustomerName);
                        var avatarColors = new[] { "av1","av2","av3","av4","av5" };
                        var avClass = avatarColors[fb.FeedbackId % 5];
                        <div class="tc-card @(fb.Rating == 5 ? "tc-card-gold" : "")">
                            <div class="tc-card-top">
                                <div class="tc-card-avatar @avClass">@initials.ToUpper()</div>
                                <div class="tc-card-info">
                                    <p class="tc-card-name">@fb.CustomerName</p>
                                    <p class="tc-card-role">Verified Customer · @fb.SubmittedAt.ToString("MMM yyyy")</p>
                                </div>
                                <span class="tc-verified">✓ Verified</span>
                            </div>
                            <div class="tc-card-stars">
                                @for (int s = 1; s <= 5; s++) { <span style="color:@(s <= fb.Rating ? "#FFE500" : "rgba(255,229,0,0.2)")">★</span> }
                            </div>
                            <p class="tc-card-text">"@fb.ReviewText"</p>
                            <div class="tc-card-tag">@fb.PolicyTag</div>
                        </div>
                    }
                }
            </div>
        </div>

        <!-- Marquee Row 2 — scrolls right -->
        <div class="tc-marquee-wrapper">
            <div class="tc-marquee tc-marquee-right">
                @for (int loop = 0; loop < 2; loop++)
                {
                    <!-- Card A -->
                    <div class="tc-card">
                        <div class="tc-card-top">
                            <div class="tc-card-avatar av4">NA</div>
                            <div class="tc-card-info">
                                <p class="tc-card-name">Nadia Ansari</p>
                                <p class="tc-card-role">Architect, Multan</p>
                            </div>
                            <span class="tc-verified">✓ Verified</span>
                        </div>
                        <div class="tc-card-stars">★★★★★</div>
                        <p class="tc-card-text">Mujhe koi umeed nahi thi itni jaldi claim hoga lekin VehicleShield ne poori raqam 4 din mein de di. Shukriya team!</p>
                        <div class="tc-card-tag">Claim Settled</div>
                    </div>
                    <!-- Card B -->
                    <div class="tc-card tc-card-gold">
                        <div class="tc-card-top">
                            <div class="tc-card-avatar av5">BK</div>
                            <div class="tc-card-info">
                                <p class="tc-card-name">Bilal Kamran</p>
                                <p class="tc-card-role">Businessman, Rawalpindi</p>
                            </div>
                            <span class="tc-verified">✓ Verified</span>
                        </div>
                        <div class="tc-card-stars">★★★★★</div>
                        <p class="tc-card-text">Pakistan mein itni reliable vehicle insurance service pehle nahi dekhi. Hamare poore family fleet ka insurance yahan hai!</p>
                        <div class="tc-card-tag">Fleet Coverage</div>
                    </div>
                    <!-- Card C -->
                    <div class="tc-card">
                        <div class="tc-card-top">
                            <div class="tc-card-avatar av1">AS</div>
                            <div class="tc-card-info">
                                <p class="tc-card-name">Ayesha Siddiqui</p>
                                <p class="tc-card-role">Doctor, Quetta</p>
                            </div>
                            <span class="tc-verified">✓ Verified</span>
                        </div>
                        <div class="tc-card-stars">★★★★★</div>
                        <p class="tc-card-text">Registration se le kar policy milne tak sirf 5 minute lage. Digital Pakistan ka asli faida yahi hai. Bohot khush hoon!</p>
                        <div class="tc-card-tag">Instant Policy</div>
                    </div>
                    <!-- Card D -->
                    <div class="tc-card">
                        <div class="tc-card-top">
                            <div class="tc-card-avatar av2">OM</div>
                            <div class="tc-card-info">
                                <p class="tc-card-name">Omar Malik</p>
                                <p class="tc-card-role">Teacher, Hyderabad</p>
                            </div>
                            <span class="tc-verified">✓ Verified</span>
                        </div>
                        <div class="tc-card-stars">★★★★★</div>
                        <p class="tc-card-text">App aur website dono bohat smooth hain. Customer support walay bhi bohat helpful hain. 10/10 recommend karunga!</p>
                        <div class="tc-card-tag">Comprehensive Plan</div>
                    </div>
                    <!-- Card E -->
                    <div class="tc-card">
                        <div class="tc-card-top">
                            <div class="tc-card-avatar av3">RN</div>
                            <div class="tc-card-info">
                                <p class="tc-card-name">Rabia Nawaz</p>
                                <p class="tc-card-role">Entrepreneur, Lahore</p>
                            </div>
                            <span class="tc-verified">✓ Verified</span>
                        </div>
                        <div class="tc-card-stars">★★★★★</div>
                        <p class="tc-card-text">Meri Corolla ka accident hua, full claim mila bina kisi jhanjhat ke. VehicleShield pe poora bharosa hai mujhe!</p>
                        <div class="tc-card-tag">Claim Settled</div>
                    </div>

                    <!-- Dynamic Approved Feedbacks (Odd indexes) -->
                    @foreach (var fb in approvedFeedbacks.Where((f, idx) => idx % 2 != 0))
                    {
                        var nameParts = fb.CustomerName.Split(' ', StringSplitOptions.RemoveEmptyEntries);
                        var initials = nameParts.Length >= 2
                            ? $"{nameParts[0][0]}{nameParts[1][0]}"
                            : (fb.CustomerName.Length >= 2 ? fb.CustomerName.Substring(0, 2) : fb.CustomerName);
                        var avatarColors = new[] { "av1","av2","av3","av4","av5" };
                        var avClass = avatarColors[fb.FeedbackId % 5];
                        <div class="tc-card @(fb.Rating == 5 ? "tc-card-gold" : "")">
                            <div class="tc-card-top">
                                <div class="tc-card-avatar @avClass">@initials.ToUpper()</div>
                                <div class="tc-card-info">
                                    <p class="tc-card-name">@fb.CustomerName</p>
                                    <p class="tc-card-role">Verified Customer · @fb.SubmittedAt.ToString("MMM yyyy")</p>
                                </div>
                                <span class="tc-verified">✓ Verified</span>
                            </div>
                            <div class="tc-card-stars">
                                @for (int s = 1; s <= 5; s++) { <span style="color:@(s <= fb.Rating ? "#FFE500" : "rgba(255,229,0,0.2)")">★</span> }
                            </div>
                            <p class="tc-card-text">"@fb.ReviewText"</p>
                            <div class="tc-card-tag">@fb.PolicyTag</div>
                        </div>
                    }
                }
            </div>
        </div>

    </div>
</section>

