@model VehicleShield.Models.Policy
@{
    ViewData["Title"] = "Policy Details";
    Layout = "_CustomerLayout";
}

<div class="page-header">
    <div class="page-header-left">
        <h1>Policy #@Model.PolicyNumber</h1>
        <p>Comprehensive overview of policy terms, billing statements and claims history</p>
    </div>
    <div class="page-header-actions">
        <a asp-action="MyPolicies" class="btn btn-outline">Back to Policies</a>
    </div>
</div>

<div class="content-grid cols-2" style="margin-bottom: 20px;">
    <!-- Policy & Vehicle Details -->
    <div class="card">
        <div class="card-header">
            <h3>Policy Details</h3>
        </div>
        <div class="card-body">
            <div style="display:flex; flex-direction:column; gap:16px;">
                <div style="display:flex; justify-content:space-between; border-bottom: 1px solid rgba(255,255,255,0.05); padding-bottom: 8px;">
                    <span style="color:var(--text-muted); font-size:0.85rem;">Policy Status</span>
                    <span class="badge @(Model.Status == "Active" ? "badge-active" : "badge-inactive")">@Model.Status</span>
                </div>
                <div style="display:flex; justify-content:space-between; border-bottom: 1px solid rgba(255,255,255,0.05); padding-bottom: 8px;">
                    <span style="color:var(--text-muted); font-size:0.85rem;">Policy Type</span>
                    <span style="color:#fff; font-weight:600;">@Model.PolicyType</span>
                </div>
                <div style="display:flex; justify-content:space-between; border-bottom: 1px solid rgba(255,255,255,0.05); padding-bottom: 8px;">
                    <span style="color:var(--text-muted); font-size:0.85rem;">Policy Duration</span>
                    <span style="color:#fff; font-weight:600;">@Model.PolicyDurationYears Year(s)</span>
                </div>
                <div style="display:flex; justify-content:space-between; border-bottom: 1px solid rgba(255,255,255,0.05); padding-bottom: 8px;">
                    <span style="color:var(--text-muted); font-size:0.85rem;">Commencement Date</span>
                    <span style="color:#fff;">@Model.PolicyDate.ToString("MMM dd, yyyy")</span>
                </div>
                <div style="display:flex; justify-content:space-between; border-bottom: 1px solid rgba(255,255,255,0.05); padding-bottom: 8px;">
                    <span style="color:var(--text-muted); font-size:0.85rem;">Expiry Date</span>
                    <span style="color:#fff;">@Model.PolicyEndDate.ToString("MMM dd, yyyy")</span>
                </div>
                <div style="display:flex; justify-content:space-between; border-bottom: 1px solid rgba(255,255,255,0.05); padding-bottom: 8px;">
                    <span style="color:var(--text-muted); font-size:0.85rem;">Address Proof Text</span>
                    <span style="color:#fff; font-style:italic;">@Model.CustomerAddProve</span>
                </div>
            </div>
        </div>
    </div>

    <!-- Vehicle Details -->
    <div class="card">
        <div class="card-header">
            <h3>Vehicle Specifications</h3>
        </div>
        <div class="card-body">
            <div style="display:flex; flex-direction:column; gap:16px;">
                <div style="display:flex; justify-content:space-between; border-bottom: 1px solid rgba(255,255,255,0.05); padding-bottom: 8px;">
                    <span style="color:var(--text-muted); font-size:0.85rem;">Vehicle Model</span>
                    <span style="color:#fff; font-weight:600;">@Model.VehicleName @Model.VehicleModel</span>
                </div>
                <div style="display:flex; justify-content:space-between; border-bottom: 1px solid rgba(255,255,255,0.05); padding-bottom: 8px;">
                    <span style="color:var(--text-muted); font-size:0.85rem;">Registration Number</span>
                    <span style="color:#fff; font-weight:700;">@Model.VehicleNumber</span>
                </div>
                <div style="display:flex; justify-content:space-between; border-bottom: 1px solid rgba(255,255,255,0.05); padding-bottom: 8px;">
                    <span style="color:var(--text-muted); font-size:0.85rem;">Vehicle Rate (IDV)</span>
                    <span style="color:#fff; font-weight:600;">₹@Model.VehicleRate.ToString("N0")</span>
                </div>
                <div style="display:flex; justify-content:space-between; border-bottom: 1px solid rgba(255,255,255,0.05); padding-bottom: 8px;">
                    <span style="color:var(--text-muted); font-size:0.85rem;">Chassis Body Number</span>
                    <span style="color:#fff;">@Model.VehicleBodyNumber</span>
                </div>
                <div style="display:flex; justify-content:space-between; border-bottom: 1px solid rgba(255,255,255,0.05); padding-bottom: 8px;">
                    <span style="color:var(--text-muted); font-size:0.85rem;">Engine Number</span>
                    <span style="color:#fff;">@Model.VehicleEngineNumber</span>
                </div>
                <div style="display:flex; justify-content:space-between; border-bottom: 1px solid rgba(255,255,255,0.05); padding-bottom: 8px;">
                    <span style="color:var(--text-muted); font-size:0.85rem;">Warranty Period</span>
                    <span style="color:#fff;">@Model.VehicleWarranty</span>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Billings -->
<div class="card" style="margin-bottom: 20px;">
    <div class="card-header">
        <h3>Premium Billings & Invoices</h3>
    </div>
    <div class="card-body">
        @if (Model.Billings.Any())
        {
            <div class="table-wrap">
                <table>
                    <thead>
                        <tr>
                            <th>Bill Number</th>
                            <th>Bill Date</th>
                            <th>Amount</th>
                            <th>Payment Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var bill in Model.Billings)
                        {
                            <tr>
                                <td style="font-weight: 700; color: #fff;">@bill.BillNo</td>
                                <td>@bill.BillDate.ToString("MMM dd, yyyy")</td>
                                <td style="font-weight: 600; color: #fff;">₹@bill.Amount.ToString("N2")</td>
                                <td>
                                    <span class="badge badge-active">@bill.PaymentStatus</span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <p style="color: var(--text-muted); text-align: center; padding: 20px;">No billing records found.</p>
        }
    </div>
</div>

<!-- Claims -->
<div class="card">
    <div class="card-header">
        <h3>Claims Filed</h3>
    </div>
    <div class="card-body">
        @if (Model.Claims.Any())
        {
            <div class="table-wrap">
                <table>
                    <thead>
                        <tr>
                            <th>Claim Number</th>
                            <th>Date of Accident</th>
                            <th>Place of Accident</th>
                            <th>Claimable Amount</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var claim in Model.Claims)
                        {
                            <tr>
                                <td style="font-weight: 700; color: #fff;">@claim.ClaimNumber</td>
                                <td>@claim.DateOfAccident.ToString("MMM dd, yyyy")</td>
                                <td>@claim.PlaceOfAccident</td>
                                <td style="font-weight: 600;">₹@claim.ClaimableAmount.ToString("N2")</td>
                                <td>
                                    <span class="badge @(claim.Status == "Approved" ? "badge-active" : (claim.Status == "Pending" ? "badge-pending" : "badge-inactive"))">@claim.Status</span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <p style="color: var(--text-muted); text-align: center; padding: 20px;">No claims filed for this policy.</p>
        }
    </div>
</div>
