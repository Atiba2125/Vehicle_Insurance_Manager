@model VehicleShield.Models.Customer
@{
    ViewData["Title"] = "Submit Review";
    Layout = "_CustomerLayout";
    var existing = ViewBag.ExistingFeedback as VehicleShield.Models.CustomerFeedback;
    var policyTypes = ViewBag.PolicyTypes as List<string> ?? new List<string>();
    int existingRating = existing?.Rating ?? 0;
}

<div class="page-header">
    <div class="page-header-left">
        <h1>My <span class="gradient-text">Review</span></h1>
        <p>Share your experience — your feedback will be displayed on the website</p>
    </div>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert-success-box" style="background:rgba(34,197,94,0.12);border:1px solid rgba(34,197,94,0.35);border-radius:14px;padding:16px 20px;margin-bottom:22px;display:flex;align-items:center;gap:12px;color:#4ade80;">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        <span>@TempData["SuccessMessage"]</span>
    </div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div style="background:rgba(239,68,68,0.12);border:1px solid rgba(239,68,68,0.35);border-radius:14px;padding:16px 20px;margin-bottom:22px;display:flex;align-items:center;gap:12px;color:#f87171;">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
        <span>@TempData["ErrorMessage"]</span>
    </div>
}

<div style="display:grid;grid-template-columns:1fr 1fr;gap:22px;align-items:start">

    <!-- FORM CARD -->
    <div class="card">
        <div class="card-header">
            <h3>@(existing != null ? "Update Review" : "Submit New Review")</h3>
        </div>
        <div class="card-body">
            <form method="post" asp-action="SubmitFeedback" asp-controller="Customer">
                @Html.AntiForgeryToken()

                <!-- Star Rating -->
                <div style="margin-bottom:22px">
                    <label style="font-size:0.82rem;color:var(--text-muted);font-weight:600;display:block;margin-bottom:10px">SELECT RATING *</label>
                    <div class="star-rating" id="starRating">
                        @for (int i = 1; i <= 5; i++)
                        {
                            <button type="button" class="star-btn @(i <= existingRating ? "active" : "")" data-val="@i">★</button>
                        }
                    </div>
                    <input type="hidden" name="rating" id="ratingInput" value="@existingRating" />
                    <p id="ratingLabel" style="font-size:0.78rem;color:var(--text-muted);margin-top:6px">
                        @(existingRating == 5 ? "Excellent!" : existingRating == 4 ? "Very Good!" : existingRating == 3 ? "Good" : existingRating == 2 ? "Fair" : existingRating == 1 ? "Poor" : "Select star rating")
                    </p>
                </div>

                <!-- Policy Tag -->
                <div style="margin-bottom:18px">
                    <label style="font-size:0.82rem;color:var(--text-muted);font-weight:600;display:block;margin-bottom:8px">POLICY TYPE (Optional)</label>
                    <select name="policyTag" class="form-control-dark">
                        <option value="General" selected="@(existing?.PolicyTag == "General" || existing == null)">General Experience</option>
                        @foreach (var pt in policyTypes)
                        {
                            <option value="@pt" selected="@(existing?.PolicyTag == pt)">@pt</option>
                        }
                        <option value="Claim Settled" selected="@(existing?.PolicyTag == "Claim Settled")">Claim Settled</option>
                        <option value="Fast Support" selected="@(existing?.PolicyTag == "Fast Support")">Fast Support</option>
                    </select>
                </div>

                <!-- Review Text -->
                <div style="margin-bottom:22px">
                    <label style="font-size:0.82rem;color:var(--text-muted);font-weight:600;display:block;margin-bottom:8px">YOUR REVIEW *</label>
                    <textarea name="reviewText" class="form-control-dark" rows="5"
                              placeholder="Write your experience here... (minimum 10 characters)"
                              maxlength="500" required>@(existing?.ReviewText)</textarea>
                    <p style="font-size:0.72rem;color:var(--text-muted);margin-top:5px">Maximum 500 characters</p>
                </div>

                <button type="submit" class="btn btn-primary" style="width:100%">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    @(existing != null ? "Update Review" : "Submit Review")
                </button>
            </form>
        </div>
    </div>

    <!-- STATUS / PREVIEW CARD -->
    <div style="display:flex;flex-direction:column;gap:20px">

        <!-- Current Status -->
        <div class="card">
            <div class="card-header"><h3>Review Status</h3></div>
            <div class="card-body">
                @if (existing != null)
                {
                    <div style="display:flex;align-items:center;gap:14px;padding:16px;background:var(--sidebar-bg);border-radius:12px;margin-bottom:16px">
                        <div style="width:48px;height:48px;border-radius:50%;background:linear-gradient(135deg,var(--primary),var(--primary-light));display:flex;align-items:center;justify-content:center;font-size:1.3rem;font-weight:700;color:#fff;flex-shrink:0">
                            @(string.IsNullOrEmpty(existing.CustomerName) ? "?" : existing.CustomerName.Substring(0, 1).ToUpper())
                        </div>
                        <div>
                            <p style="font-weight:700;color:#fff;margin-bottom:2px">@existing.CustomerName</p>
                            <div style="color:#FFE500">@(new string('★', existing.Rating))@(new string('☆', 5 - existing.Rating))</div>
                        </div>
                        <div style="margin-left:auto">
                            @if (existing.IsApproved)
                            {
                                <span class="badge badge-active">✓ Approved</span>
                            }
                            else
                            {
                                <span class="badge badge-pending">⏳ Pending</span>
                            }
                        </div>
                    </div>
                    <p style="font-size:0.85rem;color:var(--text-muted);font-style:italic;line-height:1.6">"@existing.ReviewText"</p>
                    <div style="display:flex;justify-content:space-between;margin-top:12px;font-size:0.75rem;color:var(--text-muted)">
                        <span class="tc-card-tag" style="font-size:0.72rem;padding:3px 10px">@existing.PolicyTag</span>
                        <span>Submitted: @existing.SubmittedAt.ToString("MMM dd, yyyy")</span>
                    </div>
                    @if (!existing.IsApproved)
                    {
                        <div style="margin-top:14px;padding:12px;background:rgba(251,191,36,0.08);border:1px solid rgba(251,191,36,0.2);border-radius:10px">
                            <p style="font-size:0.78rem;color:#fbbf24;margin:0">⏳ Your review is pending approval. It will show on the website once approved.</p>
                        </div>
                    }
                    else
                    {
                        <div style="margin-top:14px;padding:12px;background:rgba(34,197,94,0.08);border:1px solid rgba(34,197,94,0.2);border-radius:10px">
                            <p style="font-size:0.78rem;color:#4ade80;margin:0">✓ Your review is approved! It is now live on the website in "What Our Customers Say" section.</p>
                        </div>
                    }
                }
                else
                {
                    <div style="text-align:center;padding:30px 20px">
                        <div style="font-size:3rem;margin-bottom:12px">💬</div>
                        <p style="color:var(--text-muted);font-size:0.85rem">You have not submitted a review yet.</p>
                        <p style="color:var(--text-muted);font-size:0.78rem;margin-top:6px">Fill the form on the left to share your experience!</p>
                    </div>
                }
            </div>
        </div>

        <!-- Info Card -->
        <div class="card">
            <div class="card-header"><h3>How It Works</h3></div>
            <div class="card-body">
                <div style="display:flex;flex-direction:column;gap:14px">
                    <div style="display:flex;align-items:flex-start;gap:12px">
                        <div style="width:28px;height:28px;border-radius:50%;background:rgba(108,99,255,0.2);display:flex;align-items:center;justify-content:center;font-size:0.8rem;font-weight:700;color:var(--primary);flex-shrink:0">1</div>
                        <div><p style="font-weight:600;color:#fff;font-size:0.82rem;margin-bottom:2px">Submit Review</p><p style="color:var(--text-muted);font-size:0.75rem">Choose rating and write your experience</p></div>
                    </div>
                    <div style="display:flex;align-items:flex-start;gap:12px">
                        <div style="width:28px;height:28px;border-radius:50%;background:rgba(251,191,36,0.15);display:flex;align-items:center;justify-content:center;font-size:0.8rem;font-weight:700;color:#fbbf24;flex-shrink:0">2</div>
                        <div><p style="font-weight:600;color:#fff;font-size:0.82rem;margin-bottom:2px">Admin Moderation</p><p style="color:var(--text-muted);font-size:0.75rem">Admin can unpublish or delete inappropriate reviews</p></div>
                    </div>
                    <div style="display:flex;align-items:flex-start;gap:12px">
                        <div style="width:28px;height:28px;border-radius:50%;background:rgba(34,197,94,0.15);display:flex;align-items:center;justify-content:center;font-size:0.8rem;font-weight:700;color:#4ade80;flex-shrink:0">3</div>
                        <div><p style="font-weight:600;color:#fff;font-size:0.82rem;margin-bottom:2px">Display on Website</p><p style="color:var(--text-muted);font-size:0.75rem">Live reviews are visible in the testimonials section</p></div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
.form-control-dark {
    width: 100%;
    background: var(--sidebar-bg);
    border: 1px solid var(--card-border);
    border-radius: 10px;
    padding: 12px 14px;
    color: #fff;
    font-size: 0.85rem;
    outline: none;
    resize: vertical;
    transition: border-color 0.2s;
    font-family: inherit;
    box-sizing: border-box;
}
.form-control-dark:focus { border-color: var(--primary); }
.form-control-dark option { background: #1a1a2e; }

.star-rating { display: flex; gap: 6px; }
.star-btn {
    background: none;
    border: none;
    font-size: 2rem;
    cursor: pointer;
    color: var(--card-border);
    transition: color 0.15s, transform 0.15s;
    padding: 0 2px;
    line-height: 1;
}
.star-btn.active { color: #FFE500; }
.star-btn:hover { transform: scale(1.2); }

.tc-card-tag {
    display: inline-block;
    background: rgba(108,99,255,0.15);
    color: var(--primary-light);
    border-radius: 20px;
    padding: 4px 12px;
    font-size: 0.72rem;
    font-weight: 600;
}
</style>

<script>
(function () {
    const stars = document.querySelectorAll('.star-btn');
    const input = document.getElementById('ratingInput');
    const label = document.getElementById('ratingLabel');
    const labels = ['', 'Poor', 'Fair', 'Good', 'Very Good!', 'Excellent!'];

    stars.forEach((btn, idx) => {
        btn.addEventListener('mouseenter', () => {
            stars.forEach((s, i) => s.classList.toggle('active', i <= idx));
        });
        btn.addEventListener('mouseleave', () => {
            const val = parseInt(input.value) || 0;
            stars.forEach((s, i) => s.classList.toggle('active', i < val));
        });
        btn.addEventListener('click', () => {
            const val = idx + 1;
            input.value = val;
            stars.forEach((s, i) => s.classList.toggle('active', i < val));
            label.textContent = labels[val];
        });
    });
})();
</script>
