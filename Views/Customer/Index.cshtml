@model VehicleShield.Models.Customer
@{
    ViewData["Title"] = "Customer Dashboard";
    Layout = "_CustomerLayout";
    var latestClaim = Model.Claims.OrderByDescending(c => c.DateFiled).FirstOrDefault();
    var activePolicies = Model.Policies.Where(p => p.Status == "Active").ToList();
}

<!-- Page Header -->
<div class="page-header">
    <div class="page-header-left">
        <h1>Welcome back, <span class="gradient-text">@Model.CustomerName</span> 👋</h1>
        <p>Here's an overview of your vehicle insurance portfolio</p>
    </div>
    <div class="page-header-actions">
        <a asp-action="BuyPolicy" class="btn btn-primary">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M12 5v14M5 12h14" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
            Buy New Policy
        </a>
    </div>
</div>

<!-- Stats -->
<div class="stats-grid">
    <div class="stat-card">
        <div class="stat-card-header">
            <div class="stat-icon si-blue">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" stroke="currentColor" stroke-width="2"/></svg>
            </div>
            <span class="stat-trend trend-up">↑ Active</span>
        </div>
        <div class="stat-value">@ViewBag.ActivePoliciesCount</div>
        <div class="stat-label">Active Policies</div>
    </div>
    <div class="stat-card">
        <div class="stat-card-header">
            <div class="stat-icon si-teal">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z" stroke="currentColor" stroke-width="2"/><path d="M14 2v6h6" stroke="currentColor" stroke-width="2"/></svg>
            </div>
            <span class="stat-trend trend-neutral">In Review</span>
        </div>
        <div class="stat-value">@ViewBag.TotalClaimsCount</div>
        <div class="stat-label">Total Claims Filed</div>
    </div>
    <div class="stat-card">
        <div class="stat-card-header">
            <div class="stat-icon si-green">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none"><path d="M12 1v22M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
            </div>
            <span class="stat-trend trend-up">Settled</span>
        </div>
        <div class="stat-value">Rs. @ViewBag.ApprovedClaimsAmount.ToString("N0")</div>
        <div class="stat-label">Total Claims Approved</div>
    </div>
    <div class="stat-card">
        <div class="stat-card-header">
            <div class="stat-icon si-yellow">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none"><rect x="2" y="5" width="20" height="14" rx="2" stroke="currentColor" stroke-width="2"/><path d="M2 10h20" stroke="currentColor" stroke-width="2"/></svg>
            </div>
            <span class="stat-trend trend-up">Paid</span>
        </div>
        <div class="stat-value">Rs. @ViewBag.TotalBillingAmount.ToString("N0")</div>
        <div class="stat-label">Total Premium Paid</div>
    </div>
</div>

<!-- Active Policies + Quick Actions -->
<div class="content-grid cols-3-2" style="margin-bottom:20px">
    <div class="card">
        <div class="card-header">
            <h3>My Active Policies</h3>
            <a asp-action="MyPolicies" class="card-link">View All →</a>
        </div>
        <div class="card-body">
            <div style="display:flex;flex-direction:column;gap:14px">
                @if (activePolicies.Any())
                {
                    @foreach (var policy in activePolicies)
                    {
                        <div class="policy-card">
                            <div class="policy-card-header">
                                <div>
                                    <p class="policy-vehicle" style="font-weight:700; color:#fff;">@policy.VehicleName</p>
                                    <p class="policy-num">Policy #@policy.PolicyNumber</p>
                                </div>
                                <span class="badge badge-active">Active</span>
                            </div>
                            <div class="policy-details">
                                <div class="policy-detail-item"><label>Plan Type</label><span>@policy.PolicyType</span></div>
                                <div class="policy-detail-item"><label>Number</label><span>@policy.VehicleNumber</span></div>
                                <div class="policy-detail-item"><label>Start Date</label><span>@policy.PolicyDate.ToString("MMM dd, yyyy")</span></div>
                                <div class="policy-detail-item"><label>End Date</label><span>@policy.PolicyEndDate.ToString("MMM dd, yyyy")</span></div>
                            </div>
                            <div class="progress-wrap"><div class="progress-fill" style="width:50%"></div></div>
                            <div style="display:flex;justify-content:space-between;font-size:0.72rem;color:var(--text-muted);margin-top:6px">
                                <span>Policy period active</span>
                                <span>Expires @policy.PolicyEndDate.ToString("MMM dd, yyyy")</span>
                            </div>
                            <div style="margin-top: 10px; text-align: right;">
                                <a asp-action="PolicyDetails" asp-route-id="@policy.PolicyId" class="btn btn-primary btn-sm">View Invoices</a>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <p style="color: var(--text-muted); font-size: 0.85rem; text-align: center; padding: 20px;">You don't have any active policies yet.</p>
                }
            </div>
        </div>
    </div>

    <!-- Quick Actions + Latest Claim -->
    <div style="display:flex;flex-direction:column;gap:20px">
        <div class="card">
            <div class="card-header"><h3>Quick Actions</h3></div>
            <div class="card-body">
                <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:10px">
                    <a asp-action="BuyPolicy" class="quick-action-btn">
                        <svg width="22" height="22" viewBox="0 0 24 24" fill="none"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" stroke="currentColor" stroke-width="2"/></svg>
                        <span>Buy Policy</span>
                    </a>
                    <a asp-action="MyClaims" class="quick-action-btn">
                        <svg width="22" height="22" viewBox="0 0 24 24" fill="none"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z" stroke="currentColor" stroke-width="2"/><path d="M14 2v6h6M16 13H8" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
                        <span>File Claim</span>
                    </a>
                    <a asp-action="MyPolicies" class="quick-action-btn">
                        <svg width="22" height="22" viewBox="0 0 24 24" fill="none"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4M7 10l5 5 5-5M12 15V3" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                        <span>My Policies</span>
                    </a>
                    <a asp-action="SubmitFeedback" class="quick-action-btn">
                        <svg width="22" height="22" viewBox="0 0 24 24" fill="none"><path d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z" stroke="currentColor" stroke-width="2"/></svg>
                        <span>My Review</span>
                    </a>
                    <a asp-controller="Account" asp-action="ChangePassword" class="quick-action-btn" style="grid-column:span 2">
                        <svg width="22" height="22" viewBox="0 0 24 24" fill="none"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2" stroke="currentColor" stroke-width="2"/><circle cx="12" cy="7" r="4" stroke="currentColor" stroke-width="2"/></svg>
                        <span>Security</span>
                    </a>
                </div>
            </div>
        </div>

        <!-- Claim Status -->
        <div class="card">
            <div class="card-header"><h3>Latest Claim Status</h3><a asp-action="MyClaims" class="card-link">All Claims →</a></div>
            <div class="card-body">
                @if (latestClaim != null)
                {
                    <div style="display:flex;align-items:center;gap:16px;margin-bottom:16px">
                        <div class="donut-chart">
                            <svg width="140" height="140" viewBox="0 0 140 140">
                                <circle class="donut-bg" cx="70" cy="70" r="56" stroke-width="12"/>
                                <circle class="donut-fill" id="donutFill" cx="70" cy="70" r="56" stroke-width="12" stroke="url(#dg1)" stroke-dasharray="376" stroke-dashoffset="@(latestClaim.Status == "Approved" ? "0" : (latestClaim.Status == "Pending" ? "188" : "376"))"/>
                                <defs><linearGradient id="dg1" x1="0" y1="0" x2="1" y2="1"><stop stop-color="#FFE500"/><stop offset="1" stop-color="#FF8500"/></linearGradient></defs>
                            </svg>
                            <div class="donut-center">
                                <span class="donut-val">@(latestClaim.Status == "Approved" ? "100%" : (latestClaim.Status == "Pending" ? "50%" : "0%"))</span>
                                <span class="donut-lbl">Status</span>
                            </div>
                        </div>
                        <div style="display:flex;flex-direction:column;gap:8px">
                            <div>
                                <p style="font-size:0.72rem;color:var(--text-muted)">Claim #@latestClaim.ClaimNumber</p>
                                <p style="font-size:0.85rem;font-weight:600;color:#fff">Accident Claim</p>
                            </div>
                            <span class="badge @(latestClaim.Status == "Approved" ? "badge-active" : (latestClaim.Status == "Pending" ? "badge-pending" : "badge-inactive"))">@latestClaim.Status</span>
                            <p style="font-size:0.78rem;color:var(--text-muted)">Claimable: <strong style="color:#fff">Rs. @latestClaim.ClaimableAmount.ToString("N0")</strong></p>
                        </div>
                    </div>
                    <div class="claim-steps">
                        <div class="cs-step done">
                            <div class="cs-dot"></div>
                            <span>Submitted</span>
                        </div>
                        <div class="cs-step @(latestClaim.Status == "Approved" ? "done" : "active")">
                            <div class="cs-dot"></div>
                            <span>In Review</span>
                        </div>
                        <div class="cs-step @(latestClaim.Status == "Approved" ? "active" : "")">
                            <div class="cs-dot"></div>
                            <span>Approved</span>
                        </div>
                    </div>
                }
                else
                {
                    <p style="color: var(--text-muted); font-size: 0.85rem; text-align: center; padding: 20px;">No claims filed yet.</p>
                }
            </div>
        </div>
    </div>
</div>

<style>
.quick-action-btn {
  display:flex;flex-direction:column;align-items:center;justify-content:center;gap:8px;
  background:var(--card-bg);border:1px solid var(--card-border);border-radius:12px;
  padding:16px 10px;text-decoration:none;color:var(--text-muted);font-size:0.78rem;
  font-weight:600;transition:var(--transition);text-align:center;
}
.quick-action-btn:hover{border-color:var(--primary);color:var(--primary);background:rgba(108,99,255,0.08);}
.quick-action-btn svg{color:var(--primary);}
.claim-steps{display:flex;align-items:center;gap:0}
.cs-step{display:flex;align-items:center;gap:4px;flex:1;font-size:0.7rem;color:var(--text-muted);}
.cs-step:last-child{flex:0;}
.cs-dot{width:10px;height:10px;border-radius:50%;border:2px solid var(--card-border);background:transparent;flex-shrink:0;}
.cs-step::after{content:'';flex:1;height:1px;background:var(--card-border);}
.cs-step:last-child::after{display:none;}
.cs-step.done .cs-dot{background:var(--success);border-color:var(--success);}
.cs-step.active .cs-dot{background:var(--primary);border-color:var(--primary);box-shadow:0 0 8px rgba(108,99,255,0.5);}
.cs-step.done{color:var(--success)}.cs-step.active{color:var(--primary);}
</style>
