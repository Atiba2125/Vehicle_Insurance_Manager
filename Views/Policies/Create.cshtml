@model VehicleShield.Models.Policy

@{
    ViewData["Title"] = "Create Policy";
    Layout = "_AdminLayout";
}


  

    <div class="page-header">
        <div class="page-header-left">
            <h1>Create New Policy</h1>
            <p>Generate insurance policy for a registered vehicle and customer</p>
        </div>

        <div class="page-header-actions">
            <a asp-action="Index" class="btn btn-outline">
                Back to List
            </a>
        </div>
    </div>


<div class="card" style="max-width:900px; margin:0 auto;">
    <div class="card-header">
        <h3>Policy Information Form</h3>
    </div>

    
    <div class="card-body">

        <form asp-action="Create" method="post" style="display:flex; flex-direction:column; gap:16px;">

            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly"
                 style="color:#ff6b6b;"></div>

            <div class="form-group" style="padding:0;">
                <label style="color:var(--text-muted);
font-size:0.85rem;
margin-bottom:6px;
display:block;">Customer</label>
                <select asp-for="CustomerId"
                        asp-items="ViewBag.Customers"
                        class="form-control">
                    <option value="">Select Customer</option>
                </select>
            </div>

            <div class="form-group" style="padding:0;">
                <label style="color:var(--text-muted);
font-size:0.85rem;
margin-bottom:6px;
display:block;">Vehicle</label>
                <select asp-for="VehicleId"
                        asp-items="ViewBag.Vehicles"
                        class="form-control">
                    <option value="">Select Vehicle</option>
                </select>
            </div>

            <div class="form-group" style="padding:0;">
                <label style="color:var(--text-muted);
font-size:0.85rem;
margin-bottom:6px;
display:block;">Policy Date</label>
                <input asp-for="PolicyDate"
                       type="date"
                       class="form-control" />
            </div>

            <div class="form-group" style="padding:0;">
                <label style="color:var(--text-muted);
font-size:0.85rem;
margin-bottom:6px;
display:block;">Duration (Years)</label>
                <input asp-for="PolicyDurationYears"
                       class="form-control" />
            </div>

            <div class="form-group" style="padding:0;">
                <label style="color:var(--text-muted);
font-size:0.85rem;
margin-bottom:6px;
display:block;">Policy Type</label>
                <select asp-for="PolicyType" class="form-control">
                    <option value="Third Party">Third Party</option>
                    <option value="Comprehensive">Comprehensive</option>
                    <option value="Premium Elite">Premium Elite</option>
                </select>
            </div>

            <div class="form-group" style="padding:0;">
                <label style="color:var(--text-muted);
font-size:0.85rem;
margin-bottom:6px;
display:block;">Status</label>
                <select asp-for="Status" class="form-control">
                    <option value="Active">Active</option>
                    <option value="Expired">Expired</option>
                    <option value="Lapsed">Lapsed</option>
                </select>
            </div>

            <div class="form-group" style="padding:0;">
                <label style="color:var(--text-muted);
font-size:0.85rem;
margin-bottom:6px;
display:block;">Customer Address Proof</label>
                <input asp-for="CustomerAddProve"
                       class="form-control" />
            </div>

            <button type="submit"
                    class="btn btn-primary"
                    style="justify-content:center;">
                Create Policy
            </button>

        </form>

    </div>
    

</div>
