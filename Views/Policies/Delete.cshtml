@model VehicleShield.Models.Policy

@{
    ViewData["Title"] = "Delete Policy";
    Layout = "_AdminLayout";
}

<div class="page-header">
    <div class="page-header-left">
        <h1>Delete Policy</h1>
        <p>Review policy information before permanent deletion</p>
    </div>

    <div class="page-header-actions">
        <a asp-action="Index" class="btn btn-outline">
            Back to List
        </a>
    </div>
</div>

<div class="card" style="border:1px solid rgba(255,107,107,.3);">

    <div class="card-header">
        <h3 style="color:#ff6b6b;">
            ? Confirm Policy Deletion
        </h3>
    </div>

    <div class="card-body">

        <div style="
            background:rgba(255,107,107,.08);
            border:1px solid rgba(255,107,107,.2);
            padding:15px;
            border-radius:10px;
            margin-bottom:25px;">

            This action cannot be undone. Please verify the policy details before deleting.

        </div>

        <div style="
            display:grid;
            grid-template-columns:repeat(auto-fit,minmax(350px,1fr));
            gap:20px;">

            <!-- Policy Information -->
            <div>

                <h4 style="margin-bottom:15px;">Policy Information</h4>

                <p><strong>Policy Number:</strong> @Model.PolicyNumber</p>

                <p><strong>Policy Type:</strong> @Model.PolicyType</p>

                <p style="display:flex; align-items:center; gap:8px;"><strong>Status:</strong> <span class="badge @(Model.Status == "Active" ? "badge-active" : "badge-expired")">@Model.Status</span></p>

                <p><strong>Policy Date:</strong> @Model.PolicyDate.ToString("dd MMM yyyy")</p>

                <p><strong>Expiry Date:</strong> @Model.PolicyEndDate.ToString("dd MMM yyyy")</p>

            </div>

            <!-- Customer Information -->
            <div>

                <h4 style="margin-bottom:15px;">Customer Information</h4>

                <p><strong>Name:</strong> @Model.CustomerName</p>

                <p><strong>Phone:</strong> @Model.CustomerPhone</p>

                <p><strong>Address:</strong> @Model.CustomerAddress</p>

            </div>

        </div>

        <hr style="margin:25px 0;" />

        <!-- Vehicle Information -->
        <div>

            <h4 style="margin-bottom:15px;">Vehicle Information</h4>

            <div style="
                display:grid;
                grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
                gap:15px;">

                <div>
                    <strong>Vehicle Name:</strong><br />
                    @Model.VehicleName
                </div>

                <div>
                    <strong>Model:</strong><br />
                    @Model.VehicleModel
                </div>

                <div>
                    <strong>Number:</strong><br />
                    @Model.VehicleNumber
                </div>

                <div>
                    <strong>Rate:</strong><br />
                    Rs. @Model.VehicleRate.ToString("N0")
                </div>

            </div>

        </div>

        <form asp-action="Delete" method="post" style="margin-top:30px;">

            <input type="hidden" asp-for="PolicyId" />

            <div style="display:flex; gap:12px; flex-wrap:wrap;">

                <button type="submit"
                        class="btn btn-danger"
                        style="padding:12px 30px;">
                    Delete Policy
                </button>

                <a asp-action="Details"
                   asp-route-id="@Model.PolicyId"
                   class="btn btn-outline">
                    View Details
                </a>

                <a asp-action="Index"
                   class="btn btn-outline">
                    Cancel
                </a>

            </div>

        </form>

    </div>

</div>