@model IEnumerable<VehicleShield.Models.Policy>
@{
    ViewData["Title"] = "Policies Management";
    Layout = "_AdminLayout";
}

<div class="page-header">
    <div class="page-header-left">
        <h1>Manage Policies</h1>
        <p>View, create, edit, and track registered insurance policies</p>
    </div>
    <div class="page-header-actions">
        <a asp-action="Create" class="btn btn-primary">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M12 5v14M5 12h14" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
            Create New Policy
        </a>
    </div>
</div>

<div class="card">
    <div class="card-header">
        <h3>Policy Records</h3>
    </div>
    <div class="card-body">
        <div class="table-wrap">
            <table>
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Policy Number</th>
                        <th>Customer</th>
                        <th>Vehicle</th>
                        <th>Policy Type</th>
                        <th>Status</th>
                        <th>End Date</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.PolicyId</td>
                            <td style="font-weight: 700; color: #fff;">@item.PolicyNumber</td>
                            <td>@item.CustomerName</td>
                            <td>@item.VehicleName</td>
                            <td>@item.PolicyType</td>
                            <td>
                                <span class="badge @(item.Status == "Active" ? "badge-active" : "badge-expired")">
                                    @item.Status
                                </span>
                            </td>
                            <td>@item.PolicyEndDate.ToString("dd MMM yyyy")</td>
                            <td>
                                <div style="display: flex; gap: 8px;">
                                    <a asp-action="Details" asp-route-id="@item.PolicyId" class="btn btn-primary btn-sm">Details</a>
                                    <a asp-action="Edit" asp-route-id="@item.PolicyId" class="btn btn-outline btn-sm">Edit</a>
                                    <a asp-action="Delete" asp-route-id="@item.PolicyId" class="btn btn-danger btn-sm">Delete</a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
