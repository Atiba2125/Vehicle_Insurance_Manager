@model IEnumerable<VehicleShield.Models.Expense>

@{
    ViewData["Title"] = "Expenses";
    Layout = "_AdminLayout";
}

<div class="page-header">


    <div class="page-header-left">
        <h1>Expense Management</h1>
        <p>
            Manage all business expenses, operational costs and financial records
        </p>
    </div>

    <div class="page-header-actions">

        <a asp-action="Create"
           class="btn btn-primary">
            Add Expense
        </a>

    </div>
   

</div>

<div class="card">

    <div class="card-header">
        <h3>Expense Records</h3>
    </div>

    <div class="card-body">

        <div class="table-wrap">

            <table>

                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Date</th>
                        <th>Expense Type</th>
                        <th>Amount</th>
                        <th style="width:280px;">Actions</th>
                    </tr>
                </thead>

                <tbody>

                    @if (Model.Any())
                    {
                        @foreach (var item in Model)
                        {
                            <tr>

                                <td>
                                    #@item.ExpenseId
                                </td>

                                <td>
                                    @item.DateOfExpense.ToString("dd MMM yyyy")
                                </td>

                                <td style="font-weight:700;color:#fff;">
                                    @item.TypeOfExpense
                                </td>

                                <td style="font-weight:600;color:#4ade80;">
                                    Rs. @item.AmountOfExpense.ToString("N0")
                                </td>

                                <td>

                                    <div style="
                                            display:flex;
                                            gap:8px;
                                            align-items:center;">

                                        <a asp-action="Details"
                                           asp-route-id="@item.ExpenseId"
                                           class="btn btn-primary btn-sm">
                                            Details
                                        </a>

                                        <a asp-action="Edit"
                                           asp-route-id="@item.ExpenseId"
                                           class="btn btn-outline btn-sm">
                                            Edit
                                        </a>

                                        <a asp-action="Delete"
                                           asp-route-id="@item.ExpenseId"
                                           class="btn btn-danger btn-sm">
                                            Delete
                                        </a>

                                    </div>

                                </td>

                            </tr>
                        }
                    }
                    else
                    {
                        <tr>

                            <td colspan="5"
                                style="
                                text-align:center;
                                padding:40px;
                                color:#9ca3af;">
                                No expense records found.
                            </td>

                        </tr>
                    }

                </tbody>

            </table>

        </div>

    </div>
   

</div>
