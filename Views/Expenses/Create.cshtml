@model VehicleShield.Models.Expense

@{
    ViewData["Title"] = "Create Expense";
    Layout = "_AdminLayout";
}

<div class="page-header">
    <div class="page-header-left">
        <h1>Create Expense</h1>
        <p>Add a new business expense record</p>
    </div>
    <div class="page-header-actions">
        <a asp-action="Index" class="btn btn-outline">Back to List</a>
    </div>
</div>

<div class="card" style="max-width: 600px; margin: 0 auto;">
    <div class="card-header">
        <h3>Expense Details Form</h3>
    </div>
    <div class="card-body">
        <form asp-action="Create" method="post" style="display:flex; flex-direction:column; gap:16px;">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" style="color: #ff6b6b; font-size: 0.85rem; margin-bottom: 10px;"></div>

            <div class="form-group" style="padding:0;">
                <label asp-for="DateOfExpense" style="color:var(--text-muted); font-size:0.85rem; margin-bottom:6px; display:block;">Date Of Expense</label>
                <input asp-for="DateOfExpense" type="date" class="form-control" required style="width: 100%; padding: 10px; border-radius: 8px; border: 1px solid var(--card-border); background: var(--input-bg); color: #fff;" />
                <span asp-validation-for="DateOfExpense" style="color: #ff6b6b; font-size: 0.75rem;"></span>
            </div>

            <div class="form-group" style="padding:0;">
                <label asp-for="TypeOfExpense" style="color:var(--text-muted); font-size:0.85rem; margin-bottom:6px; display:block;">Expense Type</label>
                <select asp-for="TypeOfExpense" class="form-control" required style="width: 100%; padding: 10px; border-radius: 8px; border: 1px solid var(--card-border); background: var(--input-bg); color: #fff;">
                    <option value="">Select Expense Type</option>
                    <option>Office Rent</option>
                    <option>Electricity Bill</option>
                    <option>Internet Bill</option>
                    <option>Staff Salary</option>
                    <option>Vehicle Maintenance</option>
                    <option>Insurance Processing</option>
                    <option>Marketing</option>
                    <option>Miscellaneous</option>
                </select>
                <span asp-validation-for="TypeOfExpense" style="color: #ff6b6b; font-size: 0.75rem;"></span>
            </div>

            <div class="form-group" style="padding:0;">
                <label asp-for="AmountOfExpense" style="color:var(--text-muted); font-size:0.85rem; margin-bottom:6px; display:block;">Amount Of Expense</label>
                <input asp-for="AmountOfExpense" class="form-control" placeholder="Enter Amount" required style="width: 100%; padding: 10px; border-radius: 8px; border: 1px solid var(--card-border); background: var(--input-bg); color: #fff;" />
                <span asp-validation-for="AmountOfExpense" style="color: #ff6b6b; font-size: 0.75rem;"></span>
            </div>

            <button type="submit" class="btn btn-primary" style="justify-content:center; padding:12px; margin-top:10px;">
                Save Expense
            </button>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
