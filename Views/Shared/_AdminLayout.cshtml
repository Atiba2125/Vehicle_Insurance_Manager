<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] – VehicleShield Admin</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Outfit:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/dashboard.css" asp-append-version="true" />
    @RenderSection("Styles", required: false)
</head>
<body>
    <div class="dashboard-layout">
        <!-- ========== SIDEBAR ========== -->
        <aside class="sidebar" id="sidebar">
            <a asp-controller="Home" asp-action="Index" class="sidebar-logo">
                <div class="logo-icon">
                    <svg viewBox="0 0 40 40" fill="none">
                        <path d="M20 4L36 12V28L20 36L4 28V12L20 4Z" fill="url(#asl)" />
                        <path d="M14 22L18 26L26 18" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" />
                        <defs>
                            <linearGradient id="asl" x1="4" y1="4" x2="36" y2="36" gradientUnits="userSpaceOnUse">
                                <stop stop-color="#FFD600" />
                                <stop offset="1" stop-color="#FFAB00" />
                            </linearGradient>
                        </defs>
                    </svg>
                </div>
                VehicleShield
            </a>

            <div class="sidebar-user">
                <div class="user-avatar" style="background:linear-gradient(135deg,#FFD600,#FFAB00)">AD</div>
                <div>
                    <p class="user-name">@User.Identity?.Name</p>
                    <p class="user-role">Administrator</p>
                </div>
            </div>

            <nav class="sidebar-nav">
                <span class="nav-section-label">Overview</span>
                <a asp-controller="AdminDashboard" asp-action="Index" class="sidebar-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "AdminDashboard" ? "active" : "")">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><rect x="3" y="3" width="7" height="7" rx="1" stroke="currentColor" stroke-width="2" /><rect x="14" y="3" width="7" height="7" rx="1" stroke="currentColor" stroke-width="2" /><rect x="3" y="14" width="7" height="7" rx="1" stroke="currentColor" stroke-width="2" /><rect x="14" y="14" width="7" height="7" rx="1" stroke="currentColor" stroke-width="2" /></svg>
                    Dashboard
                </a>

                <span class="nav-section-label">Management</span>
                <a asp-controller="Customers" asp-action="Index" class="sidebar-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Customers" ? "active" : "")">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2" stroke="currentColor" stroke-width="2" /><circle cx="9" cy="7" r="4" stroke="currentColor" stroke-width="2" /><path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75" stroke="currentColor" stroke-width="2" /></svg>
                    Customers
                </a>
                <a asp-controller="Vehicles" asp-action="Index" class="sidebar-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Vehicles" ? "active" : "")">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M20 8H4L2 14v4h20v-4L20 8z" stroke="currentColor" stroke-width="2" stroke-linejoin="round" /><circle cx="7" cy="18" r="2" stroke="currentColor" stroke-width="2" /><circle cx="17" cy="18" r="2" stroke="currentColor" stroke-width="2" /></svg>
                    Vehicles
                </a>
                <a asp-controller="Policies" asp-action="Index" class="sidebar-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Policies" ? "active" : "")">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" stroke="currentColor" stroke-width="2" /></svg>
                    Policies
                </a>
                <a asp-controller="Estimates" asp-action="Index" class="sidebar-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Estimates" ? "active" : "")">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M9 7h6M9 11h6M9 15h4" stroke="currentColor" stroke-width="2" stroke-linecap="round" /><rect x="4" y="3" width="16" height="18" rx="2" stroke="currentColor" stroke-width="2" /></svg>
                    Estimates
                </a>

                <span class="nav-section-label">Finance</span>
                <a asp-controller="Billing" asp-action="Index" class="sidebar-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Billing" ? "active" : "")">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><rect x="2" y="5" width="20" height="14" rx="2" stroke="currentColor" stroke-width="2" /><path d="M2 10h20" stroke="currentColor" stroke-width="2" /></svg>
                    Billing
                </a>
                <a asp-controller="Expenses" asp-action="Index" class="sidebar-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Expenses" ? "active" : "")">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M12 1v22M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6" stroke="currentColor" stroke-width="2" stroke-linecap="round" /></svg>
                    Expenses
                </a>
                <a asp-controller="Claims" asp-action="Index" class="sidebar-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Claims" ? "active" : "")">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z" stroke="currentColor" stroke-width="2" /><path d="M14 2v6h6M9 15l2 2 4-4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" /></svg>
                    Claims
                </a>

                <a asp-controller="InsurancePlans"
                   asp-action="Index"
                   class="sidebar-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "InsurancePlans" ? "active" : "")">

                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
                        <path d="M12 2L4 6V12C4 17 7.5 21.5 12 22C16.5 21.5 20 17 20 12V6L12 2Z"
                              stroke="currentColor"
                              stroke-width="2"
                              stroke-linecap="round"
                              stroke-linejoin="round" />
                        <path d="M9 12L11 14L15 10"
                              stroke="currentColor"
                              stroke-width="2"
                              stroke-linecap="round"
                              stroke-linejoin="round" />
                    </svg>

                    Insurance Plans

                </a>
                   

                <span class="nav-section-label">Analytics</span>
                <a asp-controller="Reports" asp-action="Index" class="sidebar-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Reports" ? "active" : "")">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M18 20V10M12 20V4M6 20v-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" /></svg>
                    Reports
                </a>
            </nav>

            <div class="sidebar-footer">
                <form asp-controller="Account" asp-action="Logout" method="post" id="logoutForm" style="width: 100%;">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="sidebar-logout" style="width:100%; border:none; background:none; cursor:pointer; text-align:left;">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4M16 17l5-5-5-5M21 12H9" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" /></svg>
                        Sign Out
                    </button>
                </form>
            </div>
        </aside>

        <div class="sidebar-overlay" id="sidebarOverlay" onclick="closeSidebar()"></div>

        <!-- ========== MAIN CONTENT ========== -->
        <div class="main-content">
            <header class="topbar">
                <button class="topbar-menu-btn" onclick="openSidebar()" aria-label="Menu">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M3 12h18M3 6h18M3 18h18" stroke="currentColor" stroke-width="2" stroke-linecap="round" /></svg>
                </button>
                <span class="topbar-title">@ViewData["Title"]</span>
                <div class="topbar-search">
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none"><circle cx="11" cy="11" r="8" stroke="currentColor" stroke-width="2" /><path d="M21 21l-4.35-4.35" stroke="currentColor" stroke-width="2" stroke-linecap="round" /></svg>
                    <input type="text" placeholder="Search customers, policies, claims…" />
                </div>
                <div class="topbar-actions">
                    <button class="topbar-btn" aria-label="Notifications" onclick="showToast('🔔 System operational. Check Reports section for business analysis.')">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M18 8A6 6 0 006 8c0 7-3 9-3 9h18s-3-2-3-9M13.73 21a2 2 0 01-3.46 0" stroke="currentColor" stroke-width="2" stroke-linecap="round" /></svg>
                    </button>
                    <div class="topbar-btn" style="width:auto;padding:0 10px;gap:6px;font-size:0.8rem;font-weight:600;color:var(--text);">
                        <div style="width:28px;height:28px;border-radius:8px;background:linear-gradient(135deg,#FFD600,#FFAB00);display:flex;align-items:center;justify-content:center;font-size:0.7rem;font-weight:700;color:#000">AD</div>
                        Admin
                    </div>
                </div>
            </header>

            <div class="page-content">
                @RenderBody()

                <!-- Footer -->
                <footer class="dashboard-footer">
                    <div class="footer-top-bar"></div>

                    <div class="footer-body">
                        <!-- Brand Column -->
                        <div class="footer-brand">
                            <div class="footer-brand-logo">
                                <svg viewBox="0 0 40 40" fill="none" width="28" height="28">
                                    <path d="M20 4L36 12V28L20 36L4 28V12L20 4Z" fill="url(#fsl)" />
                                    <path d="M14 22L18 26L26 18" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" />
                                    <defs>
                                        <linearGradient id="fsl" x1="4" y1="4" x2="36" y2="36" gradientUnits="userSpaceOnUse">
                                            <stop stop-color="#FFD600" />
                                            <stop offset="1" stop-color="#FFAB00" />
                                        </linearGradient>
                                    </defs>
                                </svg>
                                <span class="footer-brand-name">VehicleShield</span>
                            </div>
                            <p class="footer-tagline">Pakistan's trusted vehicle insurance management platform. Protecting every journey.</p>
                            <div class="footer-status-badge">
                                <span class="status-pulse-dot"></span>
                                <span>All Systems Operational</span>
                            </div>
                        </div>

                        <!-- Quick Links -->
                        <div class="footer-col">
                            <h4 class="footer-col-title">Management</h4>
                            <ul class="footer-links-list">
                                <li><a asp-controller="Customers" asp-action="Index" class="footer-nav-link">Customers</a></li>
                                <li><a asp-controller="Vehicles" asp-action="Index" class="footer-nav-link">Vehicles</a></li>
                                <li><a asp-controller="Policies" asp-action="Index" class="footer-nav-link">Policies</a></li>
                                <li><a asp-controller="Estimates" asp-action="Index" class="footer-nav-link">Estimates</a></li>
                            </ul>
                        </div>

                        <div class="footer-col">
                            <h4 class="footer-col-title">Finance & Reports</h4>
                            <ul class="footer-links-list">
                                <li><a asp-controller="Billing" asp-action="Index" class="footer-nav-link">Billing</a></li>
                                <li><a asp-controller="Expenses" asp-action="Index" class="footer-nav-link">Expenses</a></li>
                                <li><a asp-controller="Claims" asp-action="Index" class="footer-nav-link">Claims</a></li>
                                <li><a asp-controller="Reports" asp-action="Index" class="footer-nav-link">Reports</a></li>
                            </ul>
                        </div>

                        <!-- System Info -->
                        <div class="footer-col footer-col-system">
                            <h4 class="footer-col-title">System Info</h4>
                            <div class="footer-sys-info">
                                <div class="footer-sys-row">
                                    <span class="sys-label">Version</span>
                                    <span class="version-tag">v2.4.0-prod</span>
                                </div>
                                <div class="footer-sys-row">
                                    <span class="sys-label">Environment</span>
                                    <span class="env-tag">Production</span>
                                </div>
                                <div class="footer-sys-row">
                                    <span class="sys-label">Uptime</span>
                                    <span class="uptime-tag">99.9%</span>
                                </div>
                                <div class="footer-sys-row">
                                    <span class="sys-label">Last Backup</span>
                                    <span class="backup-tag">Today, 03:00 AM</span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Copyright Row -->
                    <div class="footer-bottom">
                        <span class="footer-copy">&copy; 2026 <strong>VehicleShield</strong>. Jami huqooq mahfooz hain.</span>
                        <div class="footer-bottom-links">
                            <a href="#" class="footer-link">Privacy Policy</a>
                            <span class="footer-dot">·</span>
                            <a href="#" class="footer-link">Terms of Service</a>
                            <span class="footer-dot">·</span>
                            <a href="#" class="footer-link">Support</a>
                        </div>
                    </div>
                </footer>
            </div>
        </div>
    </div>

    <!-- Toast Notification -->
    <div class="toast" id="toast"></div>

    <script>
        function openSidebar() {
            document.getElementById('sidebar').classList.add('open');
            document.getElementById('sidebarOverlay').classList.add('show');
        }
        function closeSidebar() {
            document.getElementById('sidebar').classList.remove('open');
            document.getElementById('sidebarOverlay').classList.remove('show');
        }
        function showToast(message) {
            const toast = document.getElementById('toast');
            if (toast) {
                toast.textContent = message;
                toast.classList.add('show');
                setTimeout(() => {
                    toast.classList.remove('show');
                }, 4000);
            }
        }

        // Show controller TempData notifications
        @if (TempData["SuccessMessage"] != null)
        {
            <text>showToast("@Html.Raw(TempData["SuccessMessage"])");</text>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <text>showToast("@Html.Raw(TempData["ErrorMessage"])");</text>
        }
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
