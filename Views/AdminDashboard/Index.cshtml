@model Tuple<List<VehicleShield.Models.Claim>, List<VehicleShield.Models.Billing>>
@{
    ViewData["Title"] = "Admin Dashboard";
    Layout = "_AdminLayout";
    var recentClaims = Model.Item1;
    var recentBillings = Model.Item2;
}

<div class="page-header">
    <div class="page-header-left">
        <h1>Welcome, <span class="gradient-text">Admin</span> 🛡️</h1>
        <p>Here's what's happening with your insurance business today.</p>
    </div>
    <div class="page-header-actions">
        <a asp-controller="Reports" asp-action="Index" class="btn btn-outline">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4M7 10l5 5 5-5M12 15V3" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Business Reports
        </a>
        <a asp-controller="Policies" asp-action="Create" class="btn btn-primary">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M12 5v14M5 12h14" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
            Add New Policy
        </a>
    </div>
</div>

<!-- Revenue Gradient Banner -->
<div class="revenue-banner">
    <div class="rb-left">
        <p class="rb-label">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M22 12h-4l-3 9L9 3l-3 9H2" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Total Revenue (This Year)
        </p>
        <div class="rb-value">PKR @ViewBag.TotalEarnings.ToString("N0")</div>
        <p class="rb-sub">
            Showroom expenses accumulated: <strong style="color:#ff6b6b;">PKR @ViewBag.TotalExpenses.ToString("N0")</strong>
        </p>
    </div>
    <div class="rb-right">
        <div class="rb-mini">
            <div class="rbm-val">PKR @((ViewBag.TotalEarnings * 0.18m).ToString("N0"))</div>
            <div class="rbm-lbl">Taxes (Est.)</div>
        </div>
        <div class="rb-mini">
            <div class="rbm-val">PKR @((ViewBag.TotalEarnings - ViewBag.TotalExpenses).ToString("N0"))</div>
            <div class="rbm-lbl">Net income</div>
        </div>
    </div>
</div>

<!-- Stat Cards -->
<div class="stats-grid">
    <div class="stat-card" style="padding-bottom:20px;">
        <div class="stat-card-header">
            <div class="stat-icon si-blue">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2" stroke="currentColor" stroke-width="2"/><circle cx="9" cy="7" r="4" stroke="currentColor" stroke-width="2"/></svg>
            </div>
            <span class="stat-trend trend-up">Users</span>
        </div>
        <div class="stat-value">@ViewBag.TotalCustomers</div>
        <div class="stat-label">Total Customers</div>
    </div>

    <div class="stat-card" style="padding-bottom:20px;">
        <div class="stat-card-header">
            <div class="stat-icon si-teal">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" stroke="currentColor" stroke-width="2"/></svg>
            </div>
            <span class="stat-trend trend-up">Active</span>
        </div>
        <div class="stat-value">@ViewBag.ActivePoliciesCount / @ViewBag.TotalPolicies</div>
        <div class="stat-label">Active Policies</div>
    </div>

    <div class="stat-card" style="padding-bottom:20px;">
        <div class="stat-card-header">
            <div class="stat-icon si-yellow">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z" stroke="currentColor" stroke-width="2"/><path d="M9 15l2 2 4-4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </div>
            <span class="stat-trend trend-neutral">Pending</span>
        </div>
        <div class="stat-value">@ViewBag.PendingClaimsCount</div>
        <div class="stat-label">Pending Claims</div>
    </div>

    <div class="stat-card" style="padding-bottom:20px;">
        <div class="stat-card-header">
            <div class="stat-icon si-green">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none"><path d="M20 8H4L2 14v4h20v-4L20 8z" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/><circle cx="7" cy="18" r="2" stroke="currentColor" stroke-width="2"/><circle cx="17" cy="18" r="2" stroke="currentColor" stroke-width="2"/></svg>
            </div>
            <span class="stat-trend trend-up">Registered</span>
        </div>
        <div class="stat-value">@ViewBag.TotalVehicles</div>
        <div class="stat-label">Registered Vehicles</div>
    </div>
</div>

<div class="content-grid cols-2" style="margin-top: 20px; margin-bottom: 20px;">
    <!-- Recent Claims -->
    <div class="card">
        <div class="card-header">
            <h3>Recent Claim Applications</h3>
            <a asp-controller="Claims" asp-action="Index" class="card-link">Manage All →</a>
        </div>
        <div class="card-body">
            @if (recentClaims.Any())
            {
                <div class="table-wrap">
                    <table>
                        <thead>
                            <tr>
                                <th>Customer Name</th>
                                <th>Claim No.</th>
                                <th>Claim Amount</th>
                                <th>Status</th>
                                <th>Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var claim in recentClaims)
                            {
                                <tr>
                                    <td>@claim.CustomerName</td>
                                    <td style="font-weight:700; color:#fff;">@claim.ClaimNumber</td>
                                    <td style="font-weight:600; color:#fff;">PKR @claim.ClaimableAmount.ToString("N0")</td>
                                    <td>
                                        <span class="badge @(claim.Status == "Approved" ? "badge-active" : (claim.Status == "Pending" ? "badge-pending" : "badge-inactive"))">@claim.Status</span>
                                    </td>
                                    <td>
                                        <a asp-controller="Claims" asp-action="Details" asp-route-id="@claim.ClaimId" class="btn btn-primary btn-sm">Process</a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <p style="color:var(--text-muted); text-align:center; padding:20px;">No claim request history found.</p>
            }
        </div>
    </div>

    <!-- Recent Billings -->
    <div class="card">
        <div class="card-header">
            <h3>Recent Invoice Billings</h3>
            <a asp-controller="Billing" asp-action="Index" class="card-link">View All →</a>
        </div>
        <div class="card-body">
            @if (recentBillings.Any())
            {
                <div class="table-wrap">
                    <table>
                        <thead>
                            <tr>
                                <th>Bill No.</th>
                                <th>Customer Name</th>
                                <th>Amount</th>
                                <th>Date</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var bill in recentBillings)
                            {
                                <tr>
                                    <td style="font-weight:700; color:#fff;">@bill.BillNo</td>
                                    <td>@bill.CustomerName</td>
                                    <td style="font-weight:600; color:#fff;">PKR @bill.Amount.ToString("N0")</td>
                                    <td>@bill.BillDate.ToString("MMM dd, yyyy")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <p style="color:var(--text-muted); text-align:center; padding:20px;">No billing statements generated.</p>
            }
        </div>
    </div>
</div>
<style>

    .revenue-banner {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 30px;
        padding: 30px;
        margin: 20px 0;
        border-radius: 20px;
        background: linear-gradient(135deg,#151932,#0e1430);
        border: 1px solid rgba(108,99,255,.2);
    }

    .rb-label {
        color: #9ca3af;
        font-size: 14px;
        display: flex;
        align-items: center;
        gap: 8px;
        margin-bottom: 10px;
    }

    .rb-value {
        font-size: 42px;
        font-weight: 800;
        color: #fff;
        margin-bottom: 10px;
    }

    .rb-sub {
        color: #cbd5e1;
        font-size: 15px;
    }

    .rb-right {
        display: flex;
        gap: 15px;
    }

    .rb-mini {
        min-width: 180px;
        padding: 20px;
        border-radius: 15px;
        background: rgba(255,255,255,.04);
        text-align: center;
    }

    .rbm-val {
        font-size: 24px;
        font-weight: 700;
        color: #fff;
    }

    .rbm-lbl {
        color: #94a3b8;
        margin-top: 5px;
    }
</style>