@model VehicleShield.Models.Estimate

@{
    ViewData["Title"] = "Delete Estimate";
    Layout = "_AdminLayout";
}

<div class="page-header">
    <div class="page-header-left">
        <h1>Delete Estimate</h1>
        <p>Remove estimate record permanently</p>
    </div>
</div>

<div class="card">

    <div class="card-header">
        <h3 style="color:#ff6b6b;">
            Are you sure you want to delete this estimate?
        </h3>
    </div>

    <div class="card-body">

        <p><strong>Customer:</strong> @Model.CustomerName</p>

        <p><strong>Phone:</strong> @Model.CustomerPhone</p>

        <p><strong>Vehicle:</strong> @Model.VehicleName</p>

        <p><strong>Model:</strong> @Model.VehicleModel</p>

        <p><strong>Policy Type:</strong> @Model.VehiclePolicyType</p>

        <p><strong>Rate:</strong> Rs. @Model.VehicleRate.ToString("N0")</p>

        <form asp-action="Delete" method="post">

            @Html.AntiForgeryToken()

            <input type="hidden" asp-for="EstimateId" />

            <button type="submit"
                    class="btn btn-danger">
                Delete Estimate
            </button>

            <a asp-action="Index"
               class="btn btn-outline">
                Cancel
            </a>

        </form>

    </div>

</div>