@model VehicleShield.Models.Estimate

@{
    ViewData["Title"] = "Edit Estimate";
    Layout = "_AdminLayout";
}

<div class="page-header">
    <div class="page-header-left">
        <h1>Edit Estimate</h1>
        <p>Update estimate information</p>
    </div>

    <div class="page-header-actions">
        <a asp-action="Index" class="btn btn-outline">
            Back to List
        </a>
    </div>
</div>

<div class="card" style="max-width:800px; margin:0 auto;">
    <div class="card-header">
        <h3>Edit Estimate Form</h3>
    </div>

    <div class="card-body">

        <form asp-action="Edit" method="post"
              style="display:flex; flex-direction:column; gap:16px;">

            @Html.AntiForgeryToken()

            <input type="hidden" asp-for="EstimateId" />

            <div asp-validation-summary="ModelOnly"
                 style="color:#ff6b6b;"></div>

            <div class="form-group">
                <label>Customer Name</label>
                <input asp-for="CustomerName" class="form-control" />
            </div>

            <div class="form-group">
                <label>Customer Phone</label>
                <input asp-for="CustomerPhone" class="form-control" />
            </div>

            <div class="form-group">
                <label>Vehicle Name</label>
                <input asp-for="VehicleName" class="form-control" />
            </div>

            <div class="form-group">
                <label>Vehicle Model</label>
                <input asp-for="VehicleModel" class="form-control" />
            </div>

            <div class="form-group">
                <label>Vehicle Rate</label>
                <input asp-for="VehicleRate" class="form-control" />
            </div>

            <div class="form-group">
                <label>Vehicle Warranty</label>
                <input asp-for="VehicleWarranty" class="form-control" />
            </div>

            <div class="form-group">
                <label>Policy Type</label>
                <select asp-for="VehiclePolicyType" class="form-control">
                    <option value="Third Party">Third Party</option>
                    <option value="Comprehensive">Comprehensive</option>
                    <option value="Premium Elite">Premium Elite</option>
                </select>
            </div>

            <button type="submit"
                    class="btn btn-primary"
                    style="justify-content:center;">
                Save Changes
            </button>

        </form>

    </div>
</div>