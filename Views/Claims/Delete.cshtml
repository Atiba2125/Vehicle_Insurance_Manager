@model VehicleShield.Models.Claim

@{
    ViewData["Title"] = "Delete Claim";
    Layout = "_AdminLayout";
}

<!-- ===== PAGE HEADER ===== -->
<div class="page-header">
    <div class="page-header-left">
        <h1>Delete Claim</h1>
        <p>Please confirm action before proceeding</p>
    </div>
    <div class="page-header-actions">
        <a asp-action="Index" class="btn btn-outline">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none">
                <path d="M19 12H5M12 19l-7-7 7-7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            Back to List
        </a>
    </div>
</div>

<!-- ===== WARNING BANNER ===== -->
<div class="delete-warning-banner">
    <div class="delete-warning-icon">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none">
            <path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            <line x1="12" y1="9" x2="12" y2="13" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
            <line x1="12" y1="17" x2="12.01" y2="17" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
        </svg>
    </div>
    <div>
        <h4>Are you sure you want to delete this claim?</h4>
        <p>This action will permanently delete the record and cannot be undone.</p>
    </div>
</div>

<!-- ===== CLAIM SUMMARY CARD ===== -->
<div class="card" style="max-width:700px;">
    <div class="card-header">
        <div style="display:flex;align-items:center;gap:8px;">
            <svg width="17" height="17" viewBox="0 0 24 24" fill="none" style="color:var(--danger);">
                <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z" stroke="currentColor" stroke-width="2"/>
                <path d="M14 2v6h6" stroke="currentColor" stroke-width="2"/>
            </svg>
            <h3>Claim Summary</h3>
        </div>
        <span class="delete-claim-badge">@Model.ClaimNumber</span>
    </div>

    <div class="card-body">
        <div class="delete-info-grid">

            <div class="delete-info-item">
                <span class="delete-info-label">Policy Number</span>
                <span class="delete-info-value">@Model.PolicyNumber</span>
            </div>

            <div class="delete-info-item">
                <span class="delete-info-label">Customer Name</span>
                <span class="delete-info-value">@Model.CustomerName</span>
            </div>

            <div class="delete-info-item">
                <span class="delete-info-label">Accident Date</span>
                <span class="delete-info-value">@Model.DateOfAccident.ToString("dd MMM yyyy")</span>
            </div>

            <div class="delete-info-item">
                <span class="delete-info-label">Claimable Amount</span>
                <span class="delete-info-value" style="color:var(--primary);">Rs. @Model.ClaimableAmount.ToString("N0")</span>
            </div>

            <div class="delete-info-item">
                <span class="delete-info-label">Status</span>
                <span>
                    @if (Model.Status == "Approved")
                    {
                        <span class="status-pill status-approved"><span class="status-dot" style="background:var(--success);"></span>Approved</span>
                    }
                    else if (Model.Status == "Rejected")
                    {
                        <span class="status-pill status-rejected"><span class="status-dot" style="background:var(--danger);"></span>Rejected</span>
                    }
                    else
                    {
                        <span class="status-pill status-pending"><span class="status-dot" style="background:var(--warning);"></span>Pending</span>
                    }
                </span>
            </div>

            <div class="delete-info-item">
                <span class="delete-info-label">Date Filed</span>
                <span class="delete-info-value">@Model.DateFiled.ToString("dd MMM yyyy")</span>
            </div>

        </div>

        <div class="delete-confirm-row">
            <form asp-action="Delete" asp-route-id="@Model.ClaimId" method="post" style="display:inline;">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn-delete-confirm">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none">
                        <polyline points="3 6 5 6 21 6" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                        <path d="M19 6v14a2 2 0 01-2 2H7a2 2 0 01-2-2V6M8 6V4a2 2 0 012-2h4a2 2 0 012 2v2" stroke="currentColor" stroke-width="2"/>
                    </svg>
                    Yes, Delete
                </button>
            </form>

            <a asp-action="Index" class="btn btn-outline">
                No, Go Back
            </a>
        </div>
    </div>
</div>

@section Styles {
<style>
    /* ── Warning banner ── */
    .delete-warning-banner {
        display: flex; align-items: flex-start; gap: 16px;
        background: rgba(255, 107, 107, 0.08);
        border: 1px solid rgba(255, 107, 107, 0.25);
        border-left: 4px solid var(--danger);
        border-radius: 14px; padding: 18px 20px;
        margin-bottom: 24px;
        color: var(--text);
    }
    .delete-warning-icon {
        width: 52px; height: 52px; flex-shrink: 0;
        background: rgba(255,107,107,0.12);
        border-radius: 12px;
        display: flex; align-items: center; justify-content: center;
        color: var(--danger);
    }
    .delete-warning-banner h4 { font-size: 0.97rem; font-weight: 700; margin-bottom: 4px; color: var(--danger); }
    .delete-warning-banner p  { font-size: 0.82rem; color: var(--text-muted); }

    /* ── Info grid ── */
    .delete-info-grid {
        display: grid; grid-template-columns: 1fr 1fr;
        gap: 0;
        border: 1px solid var(--card-border);
        border-radius: 12px; overflow: hidden;
        margin-bottom: 24px;
    }
    .delete-info-item {
        display: flex; flex-direction: column; gap: 4px;
        padding: 14px 18px;
        border-bottom: 1px solid var(--card-border);
        border-right: 1px solid var(--card-border);
    }
    .delete-info-item:nth-child(even) { border-right: none; }
    .delete-info-item:nth-last-child(-n+2) { border-bottom: none; }
    .delete-info-label { font-size: 0.74rem; color: var(--text-muted); font-weight: 500; }
    .delete-info-value { font-size: 0.9rem; font-weight: 600; color: var(--text); }

    /* Status pills */
    .status-pill { display:inline-flex; align-items:center; gap:6px; padding:4px 12px; border-radius:50px; font-size:0.72rem; font-weight:700; }
    .status-dot  { width:6px; height:6px; border-radius:50%; flex-shrink:0; }
    .status-approved { background:rgba(16,185,129,.1); color:var(--success); border:1px solid rgba(16,185,129,.25); }
    .status-pending  { background:rgba(255,179,0,.1);  color:var(--warning); border:1px solid rgba(255,179,0,.25); }
    .status-rejected { background:rgba(255,107,107,.1);color:var(--danger);  border:1px solid rgba(255,107,107,.25);}

    /* ── Claim number badge in header ── */
    .delete-claim-badge {
        background: rgba(255,107,107,0.08);
        border: 1px solid rgba(255,107,107,0.2);
        color: var(--danger);
        font-family: monospace; font-size: 0.8rem; font-weight: 700;
        padding: 3px 12px; border-radius: 20px;
    }

    /* ── Confirm row ── */
    .delete-confirm-row {
        display: flex; align-items: center; gap: 12px;
        padding-top: 20px;
        border-top: 1px solid var(--card-border);
    }

    /* ── Delete confirm button ── */
    .btn-delete-confirm {
        display: inline-flex; align-items: center; gap: 8px;
        padding: 11px 22px; border-radius: 10px;
        background: rgba(255,107,107,0.12);
        border: 1px solid rgba(255,107,107,0.35);
        color: var(--danger); font-size: 0.88rem; font-weight: 700;
        cursor: pointer; transition: all 0.25s ease;
    }
    .btn-delete-confirm:hover {
        background: var(--danger); color: #fff;
        transform: translateY(-1px);
        box-shadow: 0 6px 20px rgba(255,107,107,0.35);
    }

    @@media (max-width: 550px) {
        .delete-info-grid { grid-template-columns: 1fr; }
        .delete-info-item { border-right: none !important; }
        .delete-info-item:nth-last-child(-n+2) { border-bottom: 1px solid var(--card-border); }
        .delete-info-item:last-child { border-bottom: none; }
    }
</style>
}
