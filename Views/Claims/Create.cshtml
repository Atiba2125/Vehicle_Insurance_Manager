@model VehicleShield.Models.Claim

@{
    ViewData["Title"] = "Create Claim";
    Layout = "_AdminLayout";
}

<!-- ===== PAGE HEADER ===== -->
<div class="page-header">
    <div class="page-header-left">
        <h1>Naya Claim</h1>
        <p>Insurance claim darj karein — tamam fields lazmi hain</p>
    </div>
    <div class="page-header-actions">
        <a asp-action="Index" class="btn btn-outline">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none">
                <path d="M19 12H5M12 19l-7-7 7-7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            Wapas Jayein
        </a>
    </div>
</div>

<div class="card" style="max-width:780px;">
    <div class="card-header">
        <div style="display:flex;align-items:center;gap:10px;">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" style="color:var(--primary);">
                <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z" stroke="currentColor" stroke-width="2"/>
                <path d="M14 2v6h6M12 11v6M9 14h6" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
            </svg>
            <h3>Claim Information</h3>
        </div>
    </div>

    <div class="card-body">
        <form asp-action="Create" method="post">
            <div asp-validation-summary="ModelOnly" class="form-error-box"></div>

            <!-- Policy -->
            <div class="form-group">
                <label class="form-label">Policy</label>
                <div class="select-wrapper">
                    <select asp-for="PolicyId" asp-items="ViewBag.Policies" class="form-control">
                        <option value="">-- Policy chunein --</option>
                    </select>
                    <svg class="select-arrow" width="14" height="14" viewBox="0 0 24 24" fill="none">
                        <path d="M6 9l6 6 6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                </div>
                <span asp-validation-for="PolicyId" class="field-error"></span>
            </div>

            <!-- Two columns -->
            <div class="form-grid-2">

                <div class="form-group">
                    <label class="form-label">
                        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" style="color:var(--primary);">
                            <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z" stroke="currentColor" stroke-width="2"/>
                            <circle cx="12" cy="10" r="3" stroke="currentColor" stroke-width="2"/>
                        </svg>
                        Jagah (Accident ka)
                    </label>
                    <input asp-for="PlaceOfAccident" class="form-control" placeholder="Mثال: Lahore Ring Road, KPK Highway…" />
                    <span asp-validation-for="PlaceOfAccident" class="field-error"></span>
                </div>

                <div class="form-group">
                    <label class="form-label">
                        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" style="color:var(--primary);">
                            <rect x="3" y="4" width="18" height="18" rx="2" ry="2" stroke="currentColor" stroke-width="2"/>
                            <line x1="16" y1="2" x2="16" y2="6" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                            <line x1="8" y1="2" x2="8" y2="6" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                            <line x1="3" y1="10" x2="21" y2="10" stroke="currentColor" stroke-width="2"/>
                        </svg>
                        Accident ki Tarikh
                    </label>
                    <input asp-for="DateOfAccident" type="date" class="form-control" />
                    <span asp-validation-for="DateOfAccident" class="field-error"></span>
                </div>

                <div class="form-group">
                    <label class="form-label">
                        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" style="color:var(--primary);">
                            <path d="M12 1v22M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                        </svg>
                        Insured Amount (Rs.)
                    </label>
                    <div class="input-prefix-wrapper">
                        <span class="input-prefix">Rs.</span>
                        <input asp-for="InsuredAmount" class="form-control with-prefix" placeholder="0" />
                    </div>
                </div>

                <div class="form-group">
                    <label class="form-label">
                        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" style="color:var(--primary);">
                            <path d="M12 1v22M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                        </svg>
                        Claimable Amount (Rs.)
                    </label>
                    <div class="input-prefix-wrapper">
                        <span class="input-prefix">Rs.</span>
                        <input asp-for="ClaimableAmount" class="form-control with-prefix" placeholder="0" />
                    </div>
                </div>

            </div>

            <!-- Status -->
            <div class="form-group">
                <label class="form-label">Status</label>
                <div class="select-wrapper">
                    <select asp-for="Status" class="form-control">
                        <option value="Pending">⏳ Pending</option>
                        <option value="Approved">✅ Approved</option>
                        <option value="Rejected">❌ Rejected</option>
                    </select>
                    <svg class="select-arrow" width="14" height="14" viewBox="0 0 24 24" fill="none">
                        <path d="M6 9l6 6 6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                </div>
                <span asp-validation-for="Status" class="field-error"></span>
            </div>

            <!-- Actions -->
            <div class="form-actions">
                <button type="submit" class="btn btn-primary">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none">
                        <path d="M19 21H5a2 2 0 01-2-2V5a2 2 0 012-2h11l5 5v11a2 2 0 01-2 2z" stroke="currentColor" stroke-width="2"/>
                        <path d="M17 21v-8H7v8M7 3v5h8" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                    </svg>
                    Claim Save Karein
                </button>
                <a asp-action="Index" class="btn btn-outline">Wapas Jayein</a>
            </div>

        </form>
    </div>
</div>

@section Styles {
<style>
    .form-error-box {
        background: rgba(255,107,107,0.08);
        border: 1px solid rgba(255,107,107,0.3);
        border-radius: 10px; padding: 12px 16px;
        color: var(--danger); font-size: 0.85rem;
        margin-bottom: 20px;
    }
    .form-error-box:empty { display: none; }

    .form-group { display: flex; flex-direction: column; gap: 7px; margin-bottom: 20px; }

    .form-label {
        display: flex; align-items: center; gap: 6px;
        font-size: 0.82rem; font-weight: 600; color: var(--text);
    }

    .form-control {
        width: 100%; padding: 11px 14px;
        background: rgba(255,255,255,0.04);
        border: 1px solid var(--card-border);
        border-radius: 10px; color: var(--text);
        font-size: 0.88rem; font-family: 'Inter', sans-serif;
        outline: none; transition: border-color 0.25s ease, box-shadow 0.25s ease;
        appearance: none;
    }
    .form-control:focus {
        border-color: rgba(255,229,0,0.45);
        box-shadow: 0 0 0 3px rgba(255,229,0,0.08);
    }
    .form-control::placeholder { color: var(--text-muted); }
    .form-control option { background: #151515; color: var(--text); }

    /* Select wrapper */
    .select-wrapper { position: relative; }
    .select-wrapper .form-control { padding-right: 36px; }
    .select-arrow {
        position: absolute; right: 12px; top: 50%;
        transform: translateY(-50%); pointer-events: none;
        color: var(--text-muted);
    }

    /* Rs. prefix */
    .input-prefix-wrapper { position: relative; }
    .input-prefix {
        position: absolute; left: 13px; top: 50%;
        transform: translateY(-50%);
        font-size: 0.8rem; font-weight: 700;
        color: var(--primary); pointer-events: none;
    }
    .form-control.with-prefix { padding-left: 40px; }

    /* Date input calendar icon color */
    input[type="date"]::-webkit-calendar-picker-indicator { filter: invert(0.6); cursor: pointer; }

    .form-grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 0 20px; }

    .field-error { font-size: 0.76rem; color: var(--danger); }

    .form-actions {
        display: flex; align-items: center; gap: 12px;
        margin-top: 28px; padding-top: 20px;
        border-top: 1px solid var(--card-border);
    }

    @@media (max-width: 600px) {
        .form-grid-2 { grid-template-columns: 1fr; }
    }
</style>
}

@section Scripts {
@{
    await Html.RenderPartialAsync("_ValidationScriptsPartial");
}
}
