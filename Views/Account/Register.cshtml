@model VehicleShield.Models.ViewModels.RegisterVM
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Register – VehicleShield Insurance Portal</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Outfit:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/auth.css" asp-append-version="true" />
</head>
<body>
    <div class="auth-bg">
        <div class="auth-orb orb-1"></div>
        <div class="auth-orb orb-2"></div>
        <div class="grid-overlay"></div>
    </div>

    <div class="auth-layout">
        <!-- Left Panel -->
        <div class="auth-left">
            <a asp-controller="Home" asp-action="Index" class="auth-logo">
                <div class="logo-icon">
                    <svg viewBox="0 0 40 40" fill="none"><path d="M20 4L36 12V28L20 36L4 28V12L20 4Z" fill="url(#lg2)"/><path d="M14 22L18 26L26 18" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/><defs><linearGradient id="lg2" x1="4" y1="4" x2="36" y2="36" gradientUnits="userSpaceOnUse"><stop stop-color="#6C63FF"/><stop offset="1" stop-color="#3ECFCF"/></linearGradient></defs></svg>
                </div>
                VehicleShield
            </a>
            <div class="auth-left-content">
                <h1>Create Your<br/><span class="gradient-text">Account</span></h1>
                <p>Register today to get instant access to vehicle insurance policies, claims management, and 24/7 client support.</p>
                <div class="auth-features">
                    <div class="auth-feat">
                        <div class="af-icon">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" stroke="#6C63FF" stroke-width="2"/></svg>
                        </div>
                        <div>
                            <p class="af-title">100% Digital</p>
                            <p class="af-desc">Zero paperwork, instant download</p>
                        </div>
                    </div>
                    <div class="auth-feat">
                        <div class="af-icon">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z" stroke="#3ECFCF" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                        </div>
                        <div>
                            <p class="af-title">Fast Setup</p>
                            <p class="af-desc">Get covered in under 5 minutes</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Right Panel -->
        <div class="auth-right">
            <div class="auth-card" style="max-height: 90vh; overflow-y: auto;">
                <div class="auth-form-header">
                    <h2>Get Started</h2>
                    <p>Create a customer account to purchase vehicle insurance</p>
                </div>

                <form asp-controller="Account" asp-action="Register" method="post" id="registerForm" class="auth-form">
                    @Html.AntiForgeryToken()

                    <div asp-validation-summary="ModelOnly" style="color: #ff6b6b; font-size: 0.85rem; margin-bottom: 15px;"></div>

                    <div class="form-row">
                        <div class="form-group">
                            <label asp-for="FullName">Full Name</label>
                            <input type="text" asp-for="FullName" placeholder="Your full name" required />
                            <span asp-validation-for="FullName" style="color: #ff6b6b; font-size: 0.75rem;"></span>
                        </div>
                        <div class="form-group">
                            <label asp-for="Email">Email Address</label>
                            <input type="email" asp-for="Email" placeholder="your@email.com" required />
                            <span asp-validation-for="Email" style="color: #ff6b6b; font-size: 0.75rem;"></span>
                        </div>
                    </div>

                    <div class="form-row">
                        <div class="form-group">
                            <label asp-for="Phone">Phone Number</label>
                            <input type="tel" asp-for="Phone" placeholder="+91 XXXXX XXXXX" required />
                            <span asp-validation-for="Phone" style="color: #ff6b6b; font-size: 0.75rem;"></span>
                        </div>
                        <div class="form-group">
                            <label asp-for="Username">Username</label>
                            <input type="text" asp-for="Username" placeholder="Choose a username" required />
                            <span asp-validation-for="Username" style="color: #ff6b6b; font-size: 0.75rem;"></span>
                        </div>
                    </div>

                    <div class="form-group">
                        <label asp-for="Address">Home Address</label>
                        <input type="text" asp-for="Address" placeholder="Enter your full street address" required />
                        <span asp-validation-for="Address" style="color: #ff6b6b; font-size: 0.75rem;"></span>
                    </div>

                    <div class="form-row">
                        <div class="form-group">
                            <label asp-for="Password">Password</label>
                            <div class="input-with-toggle">
                                <input type="password" asp-for="Password" placeholder="Min. 4 characters" required />
                                <button type="button" class="toggle-pwd" onclick="togglePassword('Password', this)" aria-label="Toggle password">
                                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" stroke="currentColor" stroke-width="2"/><circle cx="12" cy="12" r="3" stroke="currentColor" stroke-width="2"/></svg>
                                </button>
                            </div>
                            <span asp-validation-for="Password" style="color: #ff6b6b; font-size: 0.75rem;"></span>
                        </div>
                        <div class="form-group">
                            <label asp-for="ConfirmPassword">Confirm Password</label>
                            <div class="input-with-toggle">
                                <input type="password" asp-for="ConfirmPassword" placeholder="Confirm your password" required />
                                <button type="button" class="toggle-pwd" onclick="togglePassword('ConfirmPassword', this)" aria-label="Toggle password">
                                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" stroke="currentColor" stroke-width="2"/><circle cx="12" cy="12" r="3" stroke="currentColor" stroke-width="2"/></svg>
                                </button>
                            </div>
                            <span asp-validation-for="ConfirmPassword" style="color: #ff6b6b; font-size: 0.75rem;"></span>
                        </div>
                    </div>

                    <button type="submit" class="btn-auth" style="margin-top: 10px;">
                        <span>Create Account</span>
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M5 12h14M12 5l7 7-7 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    </button>
                </form>

                <p class="auth-switch">
                    Already have an account? <a asp-controller="Account" asp-action="Login">Sign In</a>
                </p>
                <a asp-controller="Home" asp-action="Index" class="back-home">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M19 12H5M12 5l-7 7 7 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    Back to Home
                </a>
            </div>
        </div>
    </div>

    <div class="toast" id="toast"></div>

    <script src="~/js/auth.js" asp-append-version="true"></script>
</body>
</html>
