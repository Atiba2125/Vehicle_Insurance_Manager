@model VehicleShield.Models.ViewModels.ChangePasswordVM
@{
    ViewData["Title"] = "Change Password";
    Layout = "_CustomerLayout";
}

<div class="card" style="max-width: 600px; margin: 0 auto;">
    <div class="card-header">
        <h3>Change Password</h3>
    </div>
    <div class="card-body">
        <form asp-controller="Account" asp-action="ChangePassword" method="post" class="auth-form" style="padding: 0;">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" style="color: #ff6b6b; font-size: 0.85rem; margin-bottom: 15px;"></div>

            <div class="form-group" style="margin-bottom: 20px;">
                <label asp-for="CurrentPassword" style="color: var(--text-muted); font-size: 0.85rem; margin-bottom: 6px; display: block;">Current Password</label>
                <div class="input-with-toggle" style="position: relative;">
                    <input type="password" asp-for="CurrentPassword" class="form-control" placeholder="Enter current password" required style="width: 100%; padding: 12px; border-radius: 8px; border: 1px solid var(--card-border); background: var(--input-bg); color: #fff;" />
                </div>
                <span asp-validation-for="CurrentPassword" style="color: #ff6b6b; font-size: 0.75rem;"></span>
            </div>

            <div class="form-group" style="margin-bottom: 20px;">
                <label asp-for="NewPassword" style="color: var(--text-muted); font-size: 0.85rem; margin-bottom: 6px; display: block;">New Password</label>
                <div class="input-with-toggle" style="position: relative;">
                    <input type="password" asp-for="NewPassword" class="form-control" placeholder="Enter new password" required style="width: 100%; padding: 12px; border-radius: 8px; border: 1px solid var(--card-border); background: var(--input-bg); color: #fff;" />
                </div>
                <span asp-validation-for="NewPassword" style="color: #ff6b6b; font-size: 0.75rem;"></span>
            </div>

            <div class="form-group" style="margin-bottom: 24px;">
                <label asp-for="ConfirmPassword" style="color: var(--text-muted); font-size: 0.85rem; margin-bottom: 6px; display: block;">Confirm New Password</label>
                <div class="input-with-toggle" style="position: relative;">
                    <input type="password" asp-for="ConfirmPassword" class="form-control" placeholder="Confirm new password" required style="width: 100%; padding: 12px; border-radius: 8px; border: 1px solid var(--card-border); background: var(--input-bg); color: #fff;" />
                </div>
                <span asp-validation-for="ConfirmPassword" style="color: #ff6b6b; font-size: 0.75rem;"></span>
            </div>

            <button type="submit" class="btn btn-primary" style="width: 100%; justify-content: center; padding: 14px;">
                Update Password
            </button>
        </form>
    </div>
</div>
